NewPeerConnection(config)\n    67→\tif err != nil {\n    68→\t\treturn fmt.Errorf(\"create peer connection failed: %w\", err)\n    69→\t}\n    70→\tw.peerConn = pc\n    71→\n    72→\t// 创建H264视频track\n    73→\ttrack, err := webrtc.NewTrackLocalStaticH264(\n    74→\t\twebrtc.RTPCodecCapability{\n    75→\t\t\tMimeType:  \"video/h264\",\n    76→\t\t\tClockRate: 90000,\n    77→\t\t\t// SDP Fmtp line for baseline profile\n    78→\t\t\tSDPFmtpLine: \"level-asymmetry-allowed=1;packetization-mode=1;profile-level-id=42e01f\",\n    79→\t\t},\n    80→\t\t\"video\",\n    81→\t\t\"visionloop\",\n    82→\t)\n    83→\tif err != nil {\n    84→\t\treturn fmt.Errorf(\"create video track failed: %w\", err)\n    85→\t}\n    86→\tw.videoTrack = track\n    87→\n    88→\t// 添加track到peer connection\n    89→\tif _, err = pc.AddTrack(track); err != nil {\n    90→\t\treturn fmt.Errorf(\"add track failed: %w\", err)\n    91→\t}\n    92→\n    93→\t// 设置ICE候选者处理\n    94→\tpc.OnICECandidate(func(candidate *webrtc.ICECandidate) {\n    95→\t\tif candidate != nil {\n    96→\t\t\tw.signalCh <- &SignalMessage{\n    97→\t\t\t\tType:    \"ice-candidate\",\n    98→\t\t\t\tPayload: mustMarshal(candidate),\n    99→\t\t\t}\n   100→\t\t}\n   101→\t})\n   102→\n   103→\t// 设置连接状态变化\n   104→\tpc.OnConnectionStateChange(func(state webrtc.PeerConnectionState) {\n   105→\t\tw.mu.Lock()\n   106→\t\tw.connected = (state == webrtc.PeerConnectionStateConnected)\n   107→\t\tw.mu.Unlock()\n   108→\n   109→\t\tlog.Printf(\"peer connection state: %s\", state.String())\n   110→\t})\n   111→\n   112→\treturn nil\n   113→}\n   114→\n   115→// WriteVideoFrame 写入视频帧\n   116→func (w *WebRTC) WriteVideoFrame(pkt interface{}) error {\n   117→\tw.mu.RLock()\n   118→\tdefer w.mu.RUnlock()\n   119→\n   120→\tif !w.connected || w.videoTrack == nil {\n   121→\t\treturn nil\n   122→\t}\n   123→\n   124→\t// 从 EncoderPacket (encoder包) 或 mp4.EncoderPacket 获取数据\n   125→\tvar data []byte\n   126→\tswitch ep := pkt.(type) {\n   127→\tcase 