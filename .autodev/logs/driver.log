    <div v-if=\"!connected\" class=\"loading\">正在连接WebRTC...</div>\n        <!-- 事件气泡 -->\n        <transition-group name=\"fade\">\n          <div\n            v-for=\"event in recentEvents\"\n            :key=\"event.id\"\n            class=\"event-bubble\"\n            :class=\"'event-' + event.type\"\n          >\n            {{ eventText(event.type) }}\n          </div>\n        </transition-group>\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <h2>实时事件</h2>\n      <div v-if=\"recentEvents.length === 0\" class=\"empty\">暂无事件</div>\n      <div v-else class=\"event-list\">\n        <div v-for=\"event in recentEvents\" :key=\"event.id\" class=\"event-item\">\n          <span class=\"event-badge\" :class=\"'event-' + event.type\">{{ eventText(event.type) }}</span>\n          <span class=\"event-time\">{{ formatTime(event.timestamp) }}</span>\n          <img v-if=\"event.screenshot\" :src=\"'/api/screenshots/' + event.screenshot\" class=\"event-thumb\" />\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, onUnmounted } from 'vue'\nimport axios from 'axios'\n\nconst videoEl = ref(null)\nconst connected = ref(false)\nconst recentEvents = ref([])\nlet pc = null\nlet ws = null\n\nconst eventText = (type) => {\n  const map = { fall: '摔倒', cry: '哭声', noise: '异响', intruder: '陌生人' }\n  return map[type] || type\n}\n\nconst formatTime = (ts) => {\n  return new Date(ts).toLocaleTimeString()\n}\n\nonMounted(async () => {\n  await connectWebRTC()\n  await loadRecentEvents()\n\n  // 定时刷新事件\n  setInterval(loadRecentEvents, 5000)\n})\n\nonUnmounted(() => {\n  if (pc) pc.close()\n  if (ws) ws.close()\n})\n\nasync function connectWebRTC() {\n  try {\n    const config = {\n      iceServers: [{ urls: 'stun:stun.l.google.com:19302' }]\n    }\n    pc = new RTCPeerConnection(config)\n\n    pc.ontrack = (e) => {\n      if (videoEl.value) {\n        videoEl.value.srcObject = e.streams[0]\n      }\n    }\n\n    pc.onicecandidate = (e) => {\n      if (e.candidate && ws) {\n        ws.send(JSON.stringify({ type: 'ice-candidate', payload: e.candidate }))\n      }\n    }\n\n    pc.onconnectionstatechange = () => {\n      connected.value = pc.connectionState === 'connected'\n    }\n\n    // 发送offer\n    const offer = await pc.createOffer()\n    await pc.setLocalDescription(offer)\n\n    // WebSocket信令\n    ws = new WebSocket(`ws://${location.host}/api/ws/signal`)\n    ws.onopen = () => {\n      ws.send(JSON.stringify({ type: 'offer', payload: pc.localDescription.sdp }))\n    }\n\n    ws.onmessage = async (e) => {\n      const msg = JSON.parse(e.data)\n      if (msg.type === 'answer') {\n        await pc.setRemoteDescription({ type: 'answer', sdp: msg.payload })\n      } else if (msg.type === 'ice-candidate') {\n        await pc.addIceCandidate(msg.payload)\n      }\n    }\n\n  } catch (err) {\n    console.error('WebRTC error:', err)\n  }\n}\n\nasync function loadRecentEvents() {\n  try {\n    const res = await axios.get('/api/events')\n    recentEvents.value = (res.data.events || []).slice(-10).reverse()\n  } catch (err) {\n    console.error('load events error:', err)\n  }\n}\n</script>\n\n<style scoped>\n.live-view { max-width: 1200px; margin: 0 auto; }\n.video-container { position: relative; background: #000; border-radius: 8px; overflow: hidden; min-height: 400px; }\n.video-js { width: 100%; height: 400px; }\n.event-bubble {\n  position: absolute; top: 20px; right: 20px; padding: 0.5rem 1rem;\n  border-radius: 20px; font-weight: bold; animation: slideIn 0.3s ease;\n}\n.event-fall { background: #ff6b6b; }\n.event-cry { background: #ffd93d; color: #000; }\n.event-noise { background: #6bcb77; }\n.event-intruder { background: #9b59b6; }\n@keyframes slideIn { from { transform: translateX(100px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }\n.fade-enter-active, .fade-leave-active { transition: all 0.3s; }\n.fade-enter-from, .fade-leave-to { opacity: 0; transform: translateY(-20px); }\n.event-list { display: flex; flex-direction: column; gap: 0.5rem; }\n.event-item { display: flex; align-items: center; gap: 1rem; padding: 0.5rem; background: #2a2a2a; border-radius: 4px; }\n.event-time { color: #888; font-size: 0.85rem; }\n.event-thumb { width: 60px; height: 40px; object-fit: cover; border-radius: 4px; }\n.loading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #888; }\n</style>\n","structuredPatch":[{"oldStart":95,"oldLines":15,"newStart":95,"newLines":17,"lines":["     // WebSocket信令","     ws = new WebSocket(`ws://${location.host}/api/ws/signal`)","     ws.onopen = () => {","-      ws.send(JSON.stringify({ type: 'offer', payload: pc.localDescription.sdp }))","+      ws.send(JSON.stringify({ type: 'offer', payload: { type: 'offer', sdp: pc.localDescription.sdp } }))","     }"," ","     ws.onmessage = async (e) => {","       const msg = JSON.parse(e.data)","       if (msg.type === 'answer') {","-        await pc.setRemoteDescription({ type: 'answer', sdp: msg.payload })","+        const desc = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload","+        await pc.setRemoteDescription(desc)","       } else if (msg.type === 'ice-candidate') {","-        await pc.addIceCandidate(msg.payload)","+        const candidate = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload","+        await pc.addIceCandidate(candidate)","       }","     }"," "]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"id":"061307ce494516d3995ef496db1dfe43","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"Now let me also fix the webrtc.go to properly handle SignalMessage for ice-candidate (the backend's HandleSignal function also expects `json.RawMessage` for the payload of ice-candidate, which would be a JSON stringified ICECandidateInit). Let me check if the current webrtc.go HandleSignal properly handles this.\n\nActually, looking at webrtc.go:\n```go\ncase \"ice-candidate\":\n    var candidate webrtc.ICECandidateInit\n    if err := json.Unmarshal(msg.Payload, &candidate); err != nil {\n        return err\n    }\n    return w.peerConn.AddICECandidate(candidate)\n\n\n```\n\nThis unmarshals msg.Payload (which is json.RawMessage) into ICECandidateInit. Since msg.Payload is json.RawMessage, it should contain the raw JSON bytes of the candidate. When the frontend sends `{ type: 'ice-candidate', payload: { candidate: '...', sdpMid: '...', sdpMLineIndex: ... } }`, the msg.Payload will be `json.RawMessage` of that candidate object, and `json.Unmarshal` should work. Good.\n\nNow let me also look at the webrtc.go HandleSignal for the \"offer\" case:\n```go\ncase \"offer\":\n    if err := w.peerConn.SetRemoteDescription(webrtc.SessionDescription{\n        Type: webrtc.SDPTypeOffer,\n        SDP:  string(msg.Payload),\n    }); err != nil {\n```\n\nWith my frontend fix, the frontend now sends the offer payload as a structured object `{ type: 'offer', sdp: '...' }`, so msg.Payload will be the JSON bytes of that object, and converting to string gives the SDP. But the Type is lost in this process. I need to check if the frontend fix properly includes the type in the payload so the backend can extract both the type and SDP from the message.\n\nActually, I'm seeing the real issue now - the frontend is sending a structured payload with type and sdp fields, but the backend is only extracting the sdp string and ignoring the type. This means when the backend sets the remote description, it knows the SDP value but has lost the type information that was originally in the payload. I'm realizing the frontend is actually sending `pc.localDescription` as a structured RTCSessionDescription object, which gets serialized to JSON with both the type and sdp fields. Then in the backend's \"offer\" handler, I'm extracting just the sdp string and setting the type to webrtc.SDPTypeOffer, which works fine for this flow.\n\nBut there's a mismatch in the \"answer\" path - the backend sends back just the SDP string through signalCh, so when the frontend receives it, the payload is already a string rather than a parsed object. My defensive parsing handles this gracefully, though I'm wondering if the backend should be sending the full SessionDescription structure instead of just the SDP.\n\nFor the answer case, the frontend receives `msg.payload` as the SDP string directly, which matches what `pc.setRemoteDescription` expects, so that actually works out correctly. The frontend's defensive parsing with `JSON.parse` is still fine as a fallback.\n\nNow I need to implement proper WebSocket support in the API server. Gin doesn't have built-in WebSocket handling, so I'll need to work around that limitation.","signature":"8db2561986d6a0393724ff07c78e5e521b22441d2e5510e4c143144f21d57e7d"}],"model":"MiniMax-M2.7","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":56848,"output_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":19028},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"c7030919-046f-4d40-9d16-8b74cebd40f3","uuid":"f2154477-845a-4c2c-9f12-ab8ff39d8551"}
