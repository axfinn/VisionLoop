{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_1x873yr7e2zf_4","type":"tool_result","content":"     1→<template>\n     2→  <div class=\"settings-view\">\n     3→    <div class=\"card\">\n     4→      <h2>存储设置</h2>\n     5→      <div class=\"setting-item\">\n     6→        <label>最大存储空间</label>\n     7→        <div class=\"slider-group\">\n     8→          <input type=\"range\" min=\"1\" max=\"100\" v-model.number=\"settings.maxStorageGB\" />\n     9→          <span>{{ settings.maxStorageGB }} GB</span>\n    10→        </div>\n    11→        <div class=\"storage-bar\">\n    12→          <div class=\"storage-used\" :style=\"{ width: storageInfo.usedPercent + '%' }\"></div>\n    13→        </div>\n    14→        <div class=\"storage-text\">\n    15→          已使用 {{ storageInfo.usedGB.toFixed(2) }} GB / {{ storageInfo.maxGB.toFixed(2) }} GB\n    16→        </div>\n    17→      </div>\n    18→\n    19→      <div class=\"setting-item\">\n    20→        <label>录像分段时长</label>\n    21→        <select v-model.number=\"settings.segmentMin\">\n    22→          <option :value=\"1\">1 分钟</option>\n    23→          <option :value=\"5\">5 分钟</option>\n    24→          <option :value=\"10\">10 分钟</option>\n    25→          <option :value=\"30\">30 分钟</option>\n    26→        </select>\n    27→      </div>\n    28→    </div>\n    29→\n    30→    <div class=\"card\">\n    31→      <h2>检测设置</h2>\n    32→      <div class=\"setting-item\">\n    33→        <label>事件检测</label>\n    34→        <div class=\"toggle-group\">\n    35→          <label class=\"toggle\">\n    36→            <input type=\"checkbox\" v-model=\"settings.detectFall\" />\n    37→            <span>摔倒检测</span>\n    38→          </label>\n    39→          <label class=\"toggle\">\n    40→            <input type=\"checkbox\" v-model=\"settings.detectCry\" />\n    41→            <span>哭声检测</span>\n    42→          </label>\n    43→          <label class=\"toggle\">\n    44→            <input type=\"checkbox\" v-model=\"settings.detectNoise\" />\n    45→            <span>异响检测</span>\n    46→          </label>\n    47→          <label class=\"toggle\">\n    48→            <input type=\"checkbox\" v-model=\"settings.detectIntruder\" />\n    49→            <span>陌生人闯入</span>\n    50→          </label>\n    51→        </div>\n    52→      </div>\n    53→\n    54→      <div class=\"setting-item\">\n    55→        <label>检测灵敏度</label>\n    56→        <div class=\"slider-group\">\n    57→          <input type=\"range\" min=\"0.1\" max=\"1.0\" step=\"0.1\" v-model.number=\"settings.sensitivity\" />\n    58→          <span>{{ (settings.sensitivity * 100).toFixed(0) }}%</span>\n    59→        </div>\n    60→      </div>\n    61→    </div>\n    62→\n    63→    <div class=\"card\">\n    64→      <h2>系统信息</h2>\n    65→      <div class=\"info-grid\">\n    66→        <div class=\"info-item\">\n    67→          <span class=\"info-label\">版本</span>\n    68→          <span class=\"info-value\">{{ systemInfo.version }}</span>\n    69→        </div>\n    70→        <div class=\"info-item\">\n    71→          <span class=\"info-label\">运行时间</span>\n    72→          <span class=\"info-value\">{{ systemInfo.uptime }}</span>\n    73→        </div>\n    74→        <div class=\"info-item\">\n    75→          <span class=\"info-label\">编码帧数</span>\n    76→          <span class=\"info-value\">{{ systemInfo.frameCount }}</span>\n    77→        </div>\n    78→      </div>\n    79→    </div>\n    80→\n    81→    <div class=\"actions\">\n    82→      <button class=\"btn\" @click=\"saveSettings\">保存设置</button>\n    83→    </div>\n    84→  </div>\n    85→</template>\n    86→\n    87→<script setup>\n    88→import { ref, onMounted, computed } from 'vue'\n    89→import axios from 'axios'\n    90→\n    91→const settings = ref({\n    92→  maxStorageGB: 50,\n    93→  segmentMin: 5,\n    94→  detectFall: true,\n    95→  detectCry: true,\n    96→  detectNoise: true,\n    97→  detectIntruder: true,\n    98→  sensitivity: 0.7\n    99→})\n   100→\n   101→const storageInfo = ref({\n   102→  used: 0,\n   103→  max: 0,\n   104→  usedGB: 0,\n   105→  maxGB: 0,\n   106→  usedPercent: 0\n   107→})\n   108→\n   109→const systemInfo = ref({\n   110→  version: '1.0.0',\n   111→  uptime: '0:00:00',\n   112→  frameCount: 0\n   113→})\n   114→\n   115→onMounted(async () => {\n   116→  await loadSettings()\n   117→  await loadStorageInfo()\n   118→  await loadSystemInfo()\n   119→})\n   120→\n   121→async function loadSettings() {\n   122→  try {\n   123→    const res = await axios.get('/api/settings')\n   124→    if (res.data) {\n   125→      Object.assign(settings.value, res.data)\n   126→    }\n   127→  } catch (err) {\n   128→    console.error('load settings error:', err)\n   129→  }\n   130→}\n   131→\n   132→async function loadStorageInfo() {\n   133→  try {\n   134→    const res = await axios.get('/api/storage')\n   135→    storageInfo.value = res.data\n   136→  } catch (err) {\n   137→    console.error('load storage error:', err)\n   138→  }\n   139→}\n   140→\n   141→async function loadSystemInfo() {\n   142→  try {\n   143→    const res = await axios.get('/health')\n   144→    systemInfo.value.version = res.data.version || '1.0.0'\n   145→  } catch (err) {\n   146→    console.error('load system info error:', err)\n   147→  }\n   148→}\n   149→\n   150→async function saveSettings() {\n   151→  try {\n   152→    await axios.post('/api/settings', settings.value)\n   153→    alert('设置已保存')\n   154→  } catch (err) {\n   155→    console.error('save settings error:', err)\n   156→    alert('保存失败')\n   157→  }\n   158→}\n   159→</script>\n   160→\n   161→<style scoped>\n   162→.settings-view { max-width: 800px; margin: 0 auto; }\n   163→.setting-item { margin-bottom: 1.5rem; }\n   164→.setting-item label { display: block; font-weight: 600; margin-bottom: 0.5rem; }\n   165→.slider-group { display: flex; align-items: center; gap: 1rem; }\n   166→.slider-group input[type