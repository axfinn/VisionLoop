ession_id":"c7030919-046f-4d40-9d16-8b74cebd40f3","uuid":"69ff4dcb-aa6b-40b8-a506-2d71592b33b8","timestamp":"2026-03-25T12:29:37.565Z","tool_use_result":{"type":"text","file":{"filePath":"/app/data/autodev/VisionLoop-----100--2026-03-2-1774439980/internal/api/server.go","content":"\t\t\"maxGB\":       float64(max) / 1024 / 1024 / 1024,\n\t\t\"usedPercent\": float64(used) / float64(max) * 100,\n\t})\n}\n\n// handleWebRTCSignal WebRTC信令\nfunc (s *Server) handleWebRTCSignal(c *gin.Context) {\n\tif s.config.WebRTC == nil {\n\t\tc.JSON(503, gin.H{\"error\": \"webrtc not available\"})\n\t\treturn\n\t}\n\n\t// 升级为WebSocket\n\tupgrader := websocket.Upgrader{\n\t\tCheckOrigin: func(r *http.Request) bool {\n\t\t\treturn true\n\t\t},\n\t\tReadBufferSize:  1024,\n\t\tWriteBufferSize: 1024,\n\t}\n\n\tconn, err := upgrader.Upgrade(c.Writer, c.Request, nil)\n\tif err != nil {\n\t\tlog.Printf(\"websocket upgrade failed: %v\", err)\n\t\treturn\n\t}\n\tdefer conn.Close()\n\n\twebrtc := s.config.WebRTC\n\n\t// 读取客户端消息并转发到webrtc\n\tgo func() {\n\t\tfor {\n\t\t\t_, data, err := conn.ReadMessage()\n\t\t\tif err != nil {\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tvar msg webrtc.SignalMessage\n\t\t\tif err := json.Unmarshal(data, &msg); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif err := webrtc.HandleSignal(&msg); err != nil {\n\t\t\t\tlog.Printf(\"handle signal error: %v\", err)\n\t\t\t}\n\t\t}\n\t}()\n\n\t// 读取webrtc信号并转发到客户端","numLines":50,"startLine":270,"totalLines":400}}}
