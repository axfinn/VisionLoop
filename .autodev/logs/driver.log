{"type":"assistant","message":{"id":"061308317595509982b575a8924abb06","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_ncja044iwitw_1","name":"Edit","input":{"replace_all":false,"file_path":"/app/data/autodev/VisionLoop-----100--2026-03-2-1774439980/internal/api/server.go","old_string":"// handleWebRTCSignal WebRTC信令\nfunc (s *Server) handleWebRTCSignal(c *gin.Context) {\n\tif s.config.WebRTC == nil {\n\t\tc.JSON(503, gin.H{\"error\": \"webrtc not available\"})\n\t\treturn\n\t}\n\n\t// 升级为WebSocket\n\tupgrader := websocket.Upgrader{\n\t\tCheckOrigin: func(r *http.Request) bool {\n\t\t\treturn true\n\t\t},\n\t\tReadBufferSize:  1024,\n\t\tWriteBufferSize: 1024,\n\t}\n\n\tconn, err := upgrader.Upgrade(c.Writer, c.Request, nil)\n\tif err != nil {\n\t\tlog.Printf(\"websocket upgrade failed: %v\", err)\n\t\treturn\n\t}\n\tdefer conn.Close()\n\n\twebrtc := s.config.WebRTC\n\n\t// 读取客户端消息并转发到webrtc\n\tgo func() {\n\t\tfor {\n\t\t\t_, data, err := conn.ReadMessage()\n\t\t\tif err != nil {\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tvar msg webrtc.SignalMessage\n\t\t\tif err := json.Unmarshal(data, &msg); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif err := webrtc.HandleSignal(&msg); err != nil {\n\t\t\t\tlog.Printf(\"handle signal error: %v\", err)\n\t\t\t}\n\t\t}\n\t}()\n\n\t// 读取webrtc信号并转发到客户端\n\tfor {\n\t\tselect {\n\t\tcase msg, ok := <-webrtc.GetSignalCh():\n\t\t\tif !ok {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif err := conn.WriteJSON(msg); err != nil {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-c.Request.Context().Done():\n\t\t\treturn\n\t\t}\n\t}\n}","new_string":"// handleWebRTCSignal WebRTC信令\nfunc (s *Server) handleWebRTCSignal(c *gin.Context) {\n\tif s.config.WebRTC == nil {\n\t\tc.JSON(503, gin.H{\"error\": \"webrtc not available\"})\n\t\treturn\n\t}\n\n\t// 升级为WebSocket\n\tupgrader := websocket.Upgrader{\n\t\tCheckOrigin: func(r *http.Request) bool {\n\t\t\treturn true\n\t\t},\n\t\tReadBufferSize:  1024,\n\t\tWriteBufferSize: 1024,\n\t}\n\n\tconn, err := upgrader.Upgrade(c.Writer, c.Request, nil)\n\tif err != nil {\n\t\tlog.Printf(\"websocket upgrade failed: %v\", err)\n\t\treturn\n\t}\n\tdefer conn.Close()\n\n\twebrtc := s.config.WebRTC\n\tdone := make(chan struct{})\n\n\t// 读取客户端消息并转发到webrtc\n\tgo func() {\n\t\tfor {\n\t\t\t_, data, err := conn.ReadMessage()\n\t\t\tif err != nil {\n\t\t\t\tclose(done)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tvar msg webrtc.SignalMessage\n\t\t\tif err := json.Unmarshal(data, &msg); err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif err := webrtc.HandleSignal(&msg); err != nil {\n\t\t\t\tlog.Printf(\"handle signal error: %v\", err)\n\t\t\t}\n\t\t}\n\t}()\n\n\t// 读取webrtc信号并转发到客户端\n\tfor {\n\t\tselect {\n\t\tcase msg, ok := <-webrtc.GetSignalCh():\n\t\t\tif !ok {\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif err := conn.WriteJSON(msg); err != nil {\n\t\t\t\treturn\n\t\t\t}\n\t\tcase <-done:\n\t\t\treturn\n\t\t}\n\t}\n}"}}],"model":"MiniMax-M2.7","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":63978,"output_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":19028},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"c7030919-046f-4d40-9d16-8b74cebd40f3","uuid":"26986cdf-1ea1-49f7-b055-c51799c2de8b"}
