erate == 0 {\n    78→\t\tcfg.Framerate = 25\n    79→\t}\n    80→\n    81→\te := &Encoder{\n    82→\t\tcfg:    cfg,\n    83→\t\twidth:  cfg.Width,\n    84→\t\theight: cfg.Height,\n    85→\t}\n    86→\n    87→\t// 初始化软编码器\n    88→\te.recordEncoder = newSoftEncoder(cfg.Width, cfg.Height, cfg.RecordBitrate, cfg.Framerate)\n    89→\te.monitorEncoder = newSoftEncoder(cfg.Width, cfg.Height, cfg.MonitorBitrate, cfg.Framerate)\n    90→\n    91→\tlog.Printf(\"encoder initialized: %dx%d, record=%d bps, monitor=%d bps\",\n    92→\t\tcfg.Width, cfg.Height, cfg.RecordBitrate, cfg.MonitorBitrate)\n    93→\n    94→\treturn e, nil\n    95→}\n    96→\n    97→func newSoftEncoder(width, height, bitrate, framerate int) *softEncoder {\n    98→\treturn &softEncoder{\n    99→\t\twidth:     width,\n   100→\t\theight:    height,\n   101→\t\tbitrate:   bitrate,\n   102→\t\tframerate: framerate,\n   103→\t}\n   104→}\n   105→\n   106→// Width 返回宽度\n   107→func (e *Encoder) Width() int {\n   108→\treturn e.width\n   109→}\n   110→\n   111→// Height 返回高度\n   112→func (e *Encoder) Height() int {\n   113→\treturn e.height\n   114→}\n   115→\n   116→// EncodeFrame 编码一帧\n   117→func (e *Encoder) EncodeFrame(frame *capture.Frame, enableRecord, enableMonitor bool) (*EncoderPacket, *EncoderPacket, error) {\n   118→\tif frame == nil || frame.Img == nil || frame.Img.Empty() {\n   119→\t\treturn nil, nil, fmt.Errorf(\"invalid frame\")\n   120→\t}\n   121→\n   122→\te.encMutex.Lock()\n   123→\tdefer e.encMutex.Unlock()\n   124→\n   125→\te.frameCount++\n   126→\n   127→\t// 获取图像\n   128→\timg := frame.Img\n   129→\n   130→\t// 缩放到目标分辨率\n   131→\tif img.Rows() != e.height || img.Cols() != e.width {\n   132→\t\ttmp := gocv.NewMat()\n   133→\t\tgocv.Resize(*img, &tmp, image.Point{X: e.width, Y: e.height}, 0, 0, gocv.InterpolationLinear)\n   134→\t\timg = &tmp\n   135→\t\tdefer tmp.Close()\n   136→\t}\n   137→\n   138→\t// 转换为RGB\n   139→\trgb := gocv.NewMat()\n   140→\tgocv.CvtColor(*img, &rgb, gocv.ColorBGRToRGB)\n   141→\tdefer rgb.Close()\n   142→\n   143→\tvar recPkt, monPkt *EncoderPacket\n   144→\n   145→\t// 录制路编码\n   146→\tif enableRecord {\n   147→\t\trecPkt = e.recordEncoder.encode(rgb, e.frameCount)\n   148→\t\tif recPkt != nil {\n   149→\t\t\trecPkt.KeyFrame = e.frameCount%150 == 1\n   150→\t\t\trecPkt.IsRecord = true\n   151→\t\t}\n   152→\t}\n   153→\n   154→\t// 监看路编码\n   155→\tif enableMonitor {\n   156→\t\tmonPkt = e.monitorEncoder.encode(rgb, e.frameCount)\n   157→\t\tif monPkt != nil {\n   158→\t\t\tmonPkt.KeyFrame = e.frameCount%150 == 1\n   159→\t\t\tmonPkt.IsMonitor = true\n   160→\t\t}\n   161→\t}\n   162→\n   163→\treturn recPkt, monPkt, nil\n   164→}\n   165→\n   166→func (se *softEncoder) encode(mat gocv.Mat, frameCount int64) *EncoderPacket {\n   167→\tif mat.Empty() {\n   168→\t\treturn nil\n   169→\t}\n   170→\n   171→\t// 获取图像数据\n   172→\tdata, err := mat.ToBytes()\n   173→\tif err != nil {\n   174→\t\treturn nil\n   175→\t}\n   176→\n   177→\t// 简化实现：直接复制数据作为H.264 NALU\n   178→\t// 实际需要调用FFmpeg CGO进行H.264编码\n   179→\tpkt := &EncoderPacket{\n   180→\t\tData:     data,\n   181→\t\tPTS:      frameCount * int64(90000/se.framerate),\n   182→\t\tDTS:      frameCount * int64(90000/se.framerate),\n   183→\t\tKeyFrame: frameCount%150 == 1,\n   184→\t}\n   185→\n   186→\treturn pkt\n   187→}\n   188→\n   189→// Close 关闭编码器\n   190→func (e *Encoder) Close() error {\n   191→\treturn nil\n   192→}\n   193→\n   194→// GetFrameCount 获取编码帧数\n   195→func (e *Encoder) GetFrameCount() int64 {\n   196→\te.encMutex.Lock()\n   197→\tdefer e.encMutex.Unlock()\n   198→\treturn e.frameCount\n   199→}\n   200→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"c7030919-046f-4d40-9d16-8b74cebd40f3","uuid":"64bf43b4-32cb-4d5f-abe9-e670258a92e9","timestamp":"2026-03-25T12:24:29.787Z","tool_use_result":{"type":"text","file":{"filePath":"/app/data/autodev/VisionLoop-----100--2026-03-2-1774439980/internal/encoder/encoder.go","content":"package encoder\n\nimport (\n\t\"fmt\"\n\t\"image\"\n\t\"log\"\n\t\"sync\"\n\t\"time\"\n\n\t\"gocv.io/x/gocv\"\n\t\"visionloop/internal/capture\"\n)\n\n// EncoderConfig 编码器配置\ntype EncoderConfig struct {\n\tWidth          int\n\tHeight         int\n\tRecordBitrate  int // 4 Mbps\n\tMonitorBitrate int // 500 kbps\n\tFramerate      int\n}\n\n// Encoder 双路编码器\ntype Encoder struct {\n\tcfg     EncoderConfig\n\twidth   int\n\theight  int\n\tencMutex sync.Mutex\n\n\t// 编码状态\n\tframeCount int64\n\tstartTime  time.Time\n\n\t// 软编码（作为兜底）\n\trecordEncoder  *softEncoder\n\tmonitorEncoder *softEncoder\n}\n\n// softEncoder 软编码器\ntype softEncoder struct {\n\twidth     int\n\theight    int\n\tbitrate   int\n\tframerate int\n\tframeBuf  []byte\n}\n\n// EncoderPacket 编码后的数据包\ntype EncoderPacket struct {\n\tData      []byte\n\tPTS       int64\n\tDTS       int64\n\tKeyFrame  bool\n\tIsRecord  bool\n\tIsMonitor bool\n}\n\n// Release 释放数据\nfunc (p *EncoderPacket) Release() {\n\tp.Data = nil\n}\n\n// NewEncoder 创建编码器\nfunc NewEncoder(cfg EncoderConfig) (*Encoder, error) {\n\tif cfg.Width == 0 {\n\t\tcfg.Width = 640\n\t}\n\tif cfg.Height == 0 {\n\t\tcfg.Height = 480\n\t}\n\tif cfg.RecordBitrate == 0 {\n\t\tcfg.RecordBitrate = 4 * 1024 * 1024\n\t}\n\tif cfg.MonitorBitrate == 0 {\n\t\tcfg.MonitorBitrate = 500 * 1024\n\t}\n\tif cfg.Framerate == 0 {\n\t\tcfg.Framerate = 25\n\t}\n\n\te := &Encoder{\n\t\tcfg:    cfg,\n\t\twidth:  cfg.Width,\n\t\theight: cfg.Height,\n\t}\n\n\t// 初始化软编码器\n\te.recordEncoder = newSoftEncoder(cfg.Width, cfg.Height, cfg.RecordBitrate, cfg.Framerate)\n\te.monitorEncoder = newSoftEncoder(cfg.Width, cfg.Height, cfg.MonitorBitrate, cfg.Framerate)\n\n\tlog.Printf(\"encoder initialized: %dx%d, record=%d bps, monitor=%d bps\",\n\t\tcfg.Width, cfg.Height, cfg.RecordBitrate, cfg.MonitorBitrate)\n\n\treturn e, nil\n}\n\nfunc newSoftEncoder(width, height, bitrate, framerate int) *softEncoder {\n\treturn &softEncoder{\n\t\twidth:     width,\n\t\theight:    height,\n\t\tbitrate:   bitrate,\n\t\tframerate: framerate,\n\t}\n}\n\n// Width 返回宽度\nfunc (e *Encoder) Width() int {\n\treturn e.width\n}\n\n// Height 返回高度\nfunc (e *Encoder) Height() int {\n\treturn e.height\n}\n\n// EncodeFrame 编码一帧\nfunc (e *Encoder) EncodeFrame(frame *capture.Frame, enableRecord, enableMonitor bool) (*EncoderPacket, *EncoderPacket, error) {\n\tif frame == nil || frame.Img == nil || frame.Img.Empty() {\n\t\treturn nil, nil, fmt.Errorf(\"invalid frame\")\n\t}\n\n\te.encMutex.Lock()\n\tdefer e.encMutex.Unlock()\n\n\te.frameCount++\n\n\t// 获取图像\n\timg := frame.Img\n\n\t// 缩放到目标分辨率\n\tif img.Rows() != e.height || img.Cols() != e.width {\n\t\ttmp := gocv.NewMat()\n\t\tgocv.Resize(*img, &tmp, image.Point{X: e.width, Y: e.height}, 0, 0, gocv.InterpolationLinear)\n\t\timg = &tmp\n\t\tdefer tmp.Close()\n\t}\n\n\t// 转换为RGB\n\trgb := gocv.NewMat()\n\tgocv.CvtColor(*img, &rgb, gocv.ColorBGRToRGB)\n\tdefer rgb.Close()\n\n\tvar recPkt, monPkt *EncoderPacket\n\n\t// 录制路编码\n\tif enableRecord {\n\t\trecPkt = e.recordEncoder.encode(rgb, e.frameCount)\n\t\tif recPkt != nil {\n\t\t\trecPkt.KeyFrame = e.frameCount%150 == 1\n\t\t\trecPkt.IsRecord = true\n\t\t}\n\t}\n\n\t// 监看路编码\n\tif enableMonitor {\n\t\tmonPkt = e.monitorEncoder.encode(rgb, e.frameCount)\n\t\tif monPkt != nil {\n\t\t\tmonPkt.KeyFrame = e.frameCount%150 == 1\n\t\t\tmonPkt.IsMonitor = true\n\t\t}\n\t}\n\n\treturn recPkt, monPkt, nil\n}\n\nfunc (se *softEncoder) encode(mat gocv.Mat, frameCount int64) *EncoderPacket {\n\tif mat.Empty() {\n\t\treturn nil\n\t}\n\n\t// 获取图像数据\n\tdata, err := mat.ToBytes()\n\tif err != nil {\n\t\treturn nil\n\t}\n\n\t// 简化实现：直接复制数据作为H.264 NALU\n\t// 实际需要调用FFmpeg CGO进行H.264编码\n\tpkt := &EncoderPacket{\n\t\tData:     data,\n\t\tPTS:      frameCount * int64(90000/se.framerate),\n\t\tDTS:      frameCount * int64(90000/se.framerate),\n\t\tKeyFrame: frameCount%150 == 1,\n\t}\n\n\treturn pkt\n}\n\n// Close 关闭编码器\nfunc (e *Encoder) Close() error {\n\treturn nil\n}\n\n// GetFrameCount 获取编码帧数\nfunc (e *Encoder) GetFrameCount() int64 {\n\te.encMutex.Lock()\n\tdefer e.encMutex.Unlock()\n\treturn e.frameCount\n}\n","numLines":200,"startLine":1,"totalLines":200}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_w4bvq11u1et0_5","type":"tool_result","content":"     1→package storage\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"log\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"sort\"\n     9→\t\"strings\"\n    10→\t\"time\"\n    11→)\n    12→\n    13→// GC 存储垃圾回收\n    14→type GC struct {\n    15→\tdir      string\n    16→\tmaxGB    float64\n    17→\tcheckedAt time.Time\n    18→}\n    19→\n    20→// NewGC 创建GC\n    21→func NewGC(dir string, maxGB float64) *GC {\n    22→\treturn &GC{\n    23→\t\tdir:   dir,\n    24→\t\tmaxGB: maxGB,\n    25→\t}\n    26→}\n    27→\n    28→// CheckAndCleanup 检查并清理存储\n    29→func (g *GC) CheckAndCleanup() error {\n    30→\t// 限制检查频率\n    31→\tif time.Since(g.checkedAt) < 30*time.Second {\n    32→\t\treturn nil\n    33→\t}\n    34→\tg.checkedAt = time.Now()\n    35→\n    36→\t// 计算当前使用量\n    37→\ttotalSize, err := g.calculateSize()\n    38→\tif err != nil {\n    39→\t\treturn fmt.Errorf(\"calculate size failed: %w\", err)\n    40→\t}\n    41→\n    42→\tmaxBytes := int64(g.maxGB * 1024 * 1024 * 1024)\n    43→\tif totalSize < maxBytes {\n    44→\t\treturn nil\n    45→\t}\n    46→\n    47→\t// 超过阈值，删除最旧的文件\n    48→\tlog.Printf(\"storage GC triggered: %.2fGB / %.2fGB\", float64(totalSize)/1024/1024/1024, g.maxGB)\n    49→\treturn g.deleteOldest(totalSize - maxBytes*80/100) // 清理到80%阈值\n    50→}\n    51→\n    52→func (g *GC) calculateSize() (int64, error) {\n    53→\tvar total int64\n    54→\tentries, err := os.ReadDir(g.dir)\n    55→\tif err != nil {\n    56→\t\treturn 0, err\n    57→\t}\n    58→\n    59→\tfor _, entry := range entries {\n    60→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".mp4\") {\n    61→\t\t\tcontinue\n    62→\t\t}\n    63→\t\tinfo, err := entry.Info()\n    64→\t\tif err != nil {\n    65→\t\t\tcontinue\n    66→\t\t}\n    67→\t\ttotal += info.Size()\n    68→\t}\n    69→\n    70→\treturn total, nil\n    71→}\n    72→\n    73→func (g *GC) deleteOldest(targetBytes int64) error {\n    74→\tvar deleted int64\n    75→\n    76→\tentries, err := os.ReadDir(g.dir)\n    77→\tif err != nil {\n    78→\t\treturn err\n    79→\t}\n    80→\n    81→\t// 按修改时间排序\n    82→\ttype fileInfo struct {\n    83→\t\tname    string\n    84→\t\tpath    string\n    85→\t\tsize    int64\n    86→\t modTime time.Time\n    87→\t}\n    88→\n    89→\tvar files []fileInfo\n    90→\tfor _, entry := range entries {\n    91→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".mp4\") {\n    92→\t\t\tcontinue\n    93→\t\t}\n    94→\t\tinfo, err := entry.Info()\n    95→\t\tif err != nil {\n    96→\t\t\tcontinue\n    97→\t\t}\n    98→\t\tfiles = append(files, fileInfo{\n    99→\t\t\tname:    entry.Name(),\n   100→\t\t\tpath:    filepath.Join(g.dir, entry.Name()),\n   101→\t\t\tsize:    info.Size(),\n   102→\t\t\tmodTime: info.ModTime(),\n   103→\t\t})\n   104→\t}\n   105→\n   106→\tsort.Slice(files, func(i, j int) bool {\n   107→\t\treturn files[i].modTime.Before(files[j].modTime)\n   108→\t})\n   109→\n   110→\t// 删除最旧的文件直到达到目标\n   111→\tfor _, f := range files {\n   112→\t\tif deleted >= targetBytes {\n   113→\t\t\tbreak\n   114→\t\t}\n   115→\t\tif err := os.Remove(f.path); err != nil {\n   116→\t\t\tlog.Printf(\"delete old file failed: %v\", err)\n   117→\t\t\tcontinue\n   118→\t\t}\n   119→\t\tdeleted += f.size\n   120→\t\tlog.Printf(\"deleted old clip: %s (%.2fMB)\", f.name, float64(f.size)/1024/1024)\n   121→\t}\n   122→\n   123→\treturn nil\n   124→}\n   125→\n   126→// SetMaxGB 设置最大存储\n   127→func (g *GC) SetMaxGB(maxGB float64) {\n   128→\tg.maxGB = maxGB\n   129→}\n   130→\n   131→// GetMaxGB 获取最大存储\n   132→func (g *GC) GetMaxGB() float64 {\n   133→\treturn g.maxGB\n   134→}\n   135→\n   136→// GetUsage 获取当前使用量\n   137→func (g *GC) GetUsage() (used int64, max int64, err error) {\n   138→\tused, err = g.calculateSize()\n   139→\tif err != nil {\n   140→\t\treturn 0, 0, err\n   141→\t}\n   142→\tmax = int64(g.maxGB * 1024 * 1024 * 1024)\n   143→\treturn used, max, nil\n   144→}\n   145→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"c7030919-046f-4d40-9d16-8b74cebd40f3","uuid":"811cfa01-d9ad-4a8a-a7c6-a83283814557","timestamp":"2026-03-25T12:24:29.789Z","tool_use_result":{"type":"text","file":{"filePath":"/app/data/autodev/VisionLoop-----100--2026-03-2-1774439980/internal/storage/gc.go","content":"package storage\n\nimport (\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n)\n\n// GC 存储垃圾回收\ntype GC struct {\n\tdir      string\n\tmaxGB    float64\n\tcheckedAt time.Time\n}\n\n// NewGC 创建GC\nfunc NewGC(dir string, maxGB float64) *GC {\n\treturn &GC{\n\t\tdir:   dir,\n\t\tmaxGB: maxGB,\n\t}\n}\n\n// CheckAndCleanup 检查并清理存储\nfunc (g *GC) CheckAndCleanup() error {\n\t// 限制检查频率\n\tif time.Since(g.checkedAt) < 30*time.Second {\n\t\treturn nil\n\t}\n\tg.checkedAt = time.Now()\n\n\t// 计算当前使用量\n\ttotalSize, err := g.calculateSize()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"calculate size failed: %w\", err)\n\t}\n\n\tmaxBytes := int64(g.maxGB * 1024 * 1024 * 1024)\n\tif totalSize < maxBytes {\n\t\treturn nil\n\t}\n\n\t// 超过阈值，删除最旧的文件\n\tlog.Printf(\"storage GC triggered: %.2fGB / %.2fGB\", float64(totalSize)/1024/1024/1024, g.maxGB)\n\treturn g.deleteOldest(totalSize - maxBytes*80/100) // 清理到80%阈值\n}\n\nfunc (g *GC) calculateSize() (int64, error) {\n\tvar total int64\n\tentries, err := os.ReadDir(g.dir)\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".mp4\") {\n\t\t\tcontinue\n\t\t}\n\t\tinfo, err := entry.Info()\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\ttotal += info.Size()\n\t}\n\n\treturn total, nil\n}\n\nfunc (g *GC) deleteOldest(targetBytes int64) error {\n\tvar deleted int64\n\n\tentries, err := os.ReadDir(g.dir)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// 按修改时间排序\n\ttype fileInfo struct {\n\t\tname    string\n\t\tpath    string\n\t\tsize    int64\n\t modTime time.Time\n\t}\n\n\tvar files []fileInfo\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".mp4\") {\n\t\t\tcontinue\n\t\t}\n\t\tinfo, err := entry.Info()\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tfiles = append(files, fileInfo{\n\t\t\tname:    entry.Name(),\n\t\t\tpath:    filepath.Join(g.dir, entry.Name()),\n\t\t\tsize:    info.Size(),\n\t\t\tmodTime: info.ModTime(),\n\t\t})\n\t}\n\n\tsort.Slice(files, func(i, j int) bool {\n\t\treturn files[i].modTime.Before(files[j].modTime)\n\t})\n\n\t// 删除最旧的文件直到达到目标\n\tfor _, f := range files {\n\t\tif deleted >= targetBytes {\n\t\t\tbreak\n\t\t}\n\t\tif err := os.Remove(f.path); err != nil {\n\t\t\tlog.Printf(\"delete old file failed: %v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tdeleted += f.size\n\t\tlog.Printf(\"deleted old clip: %s (%.2fMB)\", f.name, float64(f.size)/1024/1024)\n\t}\n\n\treturn nil\n}\n\n// SetMaxGB 设置最大存储\nfunc (g *GC) SetMaxGB(maxGB float64) {\n\tg.maxGB = maxGB\n}\n\n// GetMaxGB 获取最大存储\nfunc (g *GC) GetMaxGB() float64 {\n\treturn g.maxGB\n}\n\n// GetUsage 获取当前使用量\nfunc (g *GC) GetUsage() (used int64, max int64, err error) {\n\tused, err = g.calculateSize()\n\tif err != nil {\n\t\treturn 0, 0, err\n\t}\n\tmax = int64(g.maxGB * 1024 * 1024 * 1024)\n\treturn used, max, nil\n}\n","numLines":145,"startLine":1,"totalLines":145}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_w4bvq11u1et0_4","type":"tool_result","content":"     1→package mp4\n     2→\n     3→import (\n     4→\t\"encoding/binary\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"sort\"\n    10→\t\"strings\"\n    11→\t\"sync\"\n    12→\t\"time\"\n    13→)\n    14→\n    15→// EncoderPacket 编码后的数据包\n    16→type EncoderPacket struct {\n    17→\tData      []byte\n    18→\tPTS      int64\n    19→\tDTS      int64\n    20→\tKeyFrame bool\n    21→\tIsRecord  bool\n    22→\tIsMonitor bool\n    23→}\n    24→\n    25→// Release 释放数据\n    26→func (p *EncoderPacket) Release() {\n    27→\tp.Data = nil\n    28→}\n    29→\n    30→// MP4Writer MP4分段写入器\n    31→type MP4Writer struct {\n    32→\tmu          sync.Mutex\n    33→\tdir         string\n    34→\tsegmentMin  int\n    35→\twidth       int\n    36→\theight      int\n    37→\tbitrate     int\n    38→\n    39→\tcurrentFile *os.File\n    40→\tcurrentPath string\n    41→\tstartTime   time.Time\n    42→\tpacketCount int64\n    43→\n    44→\t// 流上下文\n    45→\tframeCount int\n    46→\tclosed     bool\n    47→}\n    48→\n    49→// StreamContext 流上下文\n    50→type StreamContext struct {\n    51→\tIndex     int\n    52→\tTimebase  Rational\n    53→\tCodecType int\n    54→}\n    55→\n    56→// Rational 有理数\n    57→type Rational struct {\n    58→\tNum int64\n    59→\tDen int64\n    60→}\n    61→\n    62→// NewMP4Writer 创建MP4写入器\n    63→func NewMP4Writer(dir string, segmentMin, width, height, bitrate int) (*MP4Writer, error) {\n    64→\tw := &MP4Writer{\n    65→\t\tdir:        dir,\n    66→\t\tsegmentMin: segmentMin,\n    67→\t\twidth:      width,\n    68→\t\theight:     height,\n    69→\t\tbitrate:    bitrate,\n    70→\t}\n    71→\n    72→\tif err := w.newSegment(); err != nil {\n    73→\t\treturn nil, err\n    74→\t}\n    75→\n    76→\treturn w, nil\n    77→}\n    78→\n    79→// newSegment 创建新分段\n    80→func (w *MP4Writer) newSegment() error {\n    81→\tw.mu.Lock()\n    82→\tdefer w.mu.Unlock()\n    83→\n    84→\t// 关闭旧文件\n    85→\tif w.currentFile != nil {\n    86→\t\tw.currentFile.Close()\n    87→\t}\n    88→\n    89→\t// 生成新文件名\n    90→\tnow := time.Now()\n    91→\tfilename := now.Format(\"2006-01-02_15-04-05\") + \".mp4\"\n    92→\tw.currentPath = filepath.Join(w.dir, filename)\n    93→\tw.startTime = now\n    94→\tw.packetCount = 0\n    95→\n    96→\t// 创建文件\n    97→\tf, err := os.Create(w.currentPath)\n    98→\tif err != nil {\n    99→\t\treturn fmt.Errorf(\"create segment file failed: %w\", err)\n   100→\t}\n   101→\tw.currentFile = f\n   102→\n   103→\t// 写入简化的MP4 header (实际项目使用FFmpeg CGO)\n   104→\t// 这里写入一个简单的文件标记\n   105→\theader := []byte{0x00, 0x00, 0x00, 0x18, 0x66, 0x74, 0x79, 0x70} // ftyp box\n   106→\theader = append(header, []byte(\"isom\")...)\n   107→\theader = append(header, 0x00, 0x00, 0x02, 0x00)\n   108→\tif _, err := f.Write(header); err != nil {\n   109→\t\treturn err\n   110→\t}\n   111→\n   112→\tlog.Printf(\"new segment: %s\", w.currentPath)\n   113→\treturn nil\n   114→}\n   115→\n   116→// WritePacket 写入数据包\n   117→func (w *MP4Writer) WritePacket(pkt *EncoderPacket) error {\n   118→\tif pkt == nil || !pkt.IsRecord {\n   119→\t\treturn nil\n   120→\t}\n   121→\n   122→\tw.mu.Lock()\n   123→\tdefer w.mu.Unlock()\n   124→\n   125→\t// 检查是否需要切分 (5分钟 = 5*60*25帧 @25fps)\n   126→\tmaxFrames := int64(w.segmentMin * 60 * 25)\n   127→\tif w.packetCount > 0 && w.packetCount%maxFrames == 0 {\n   128→\t\tif err := w.newSegmentLocked(); err != nil {\n   129→\t\t\treturn err\n   130→\t\t}\n   131→\t}\n   132→\n   133→\t// 写入NALU长度前缀 + NALU数据\n   134→\tif len(pkt.Data) > 0 {\n   135→\t\tnaluLen := make([]byte, 4)\n   136→\t\tbinary.BigEndian.PutUint32(naluLen, uint32(len(pkt.Data)))\n   137→\n   138→\t\tif _, err := w.currentFile.Write(naluLen); err != nil {\n   139→\t\t\treturn err\n   140→\t\t}\n   141→\t\tif _, err := w.currentFile.Write(pkt.Data); err != nil {\n   142→\t\t\treturn err\n   143→\t\t}\n   144→\t\tw.packetCount++\n   145→\t}\n   146→\n   147→\treturn nil\n   148→}\n   149→\n   150→// newSegmentLocked 加锁版本\n   151→func (w *MP4Writer) newSegmentLocked() error {\n   152→\tif w.currentFile != nil {\n   153→\t\tw.currentFile.Close()\n   154→\t}\n   155→\n   156→\tnow := time.Now()\n   157→\tfilename := now.Format(\"2006-01-02_15-04-05\") + \".mp4\"\n   158→\tw.currentPath = filepath.Join(w.dir, filename)\n   159→\tw.startTime = now\n   160→\tw.packetCount = 0\n   161→\n   162→\tf, err := os.Create(w.currentPath)\n   163→\tif err != nil {\n   164→\t\treturn fmt.Errorf(\"create segment file failed: %w\", err)\n   165→\t}\n   166→\tw.currentFile = f\n   167→\n   168→\t// 写入ftyp box\n   169→\theader := []byte{0x00, 0x00, 0x00, 0x18, 0x66, 0x74, 0x79, 0x70, 0x69, 0x73, 0x6f, 0x6d, 0x00, 0x00, 0x02, 0x00}\n   170→\tf.Write(header)\n   171→\n   172→\tlog.Printf(\"new segment: %s\", w.currentPath)\n   173→\treturn nil\n   174→}\n   175→\n   176→// Flush 刷新数据\n   177→func (w *MP4Writer) Flush() error {\n   178→\tw.mu.Lock()\n   179→\tdefer w.mu.Unlock()\n   180→\n   181→\tif w.currentFile != nil {\n   182→\t\treturn w.currentFile.Sync()\n   183→\t}\n   184→\treturn nil\n   185→}\n   186→\n   187→// Close 关闭写入器\n   188→func (w *MP4Writer) Close() error {\n   189→\tw.mu.Lock()\n   190→\tdefer w.mu.Unlock()\n   191→\n   192→\tw.closed = true\n   193→\tif w.currentFile != nil {\n   194→\t\terr := w.currentFile.Close()\n   195→\t\tw.currentFile = nil\n   196→\t\treturn err\n   197→\t}\n   198→\treturn nil\n   199→}\n   200→\n   201→// CurrentPath 返回当前文件路径\n   202→func (w *MP4Writer) CurrentPath() string {\n   203→\tw.mu.Lock()\n   204→\tdefer w.mu.Unlock()\n   205→\treturn w.currentPath\n   206→}\n   207→\n   208→// MP4FileInfo MP4文件信息\n   209→type MP4FileInfo struct {\n   210→\tName      string\n   211→\tPath      string\n   212→\tSize      int64\n   213→\tDuration  time.Duration\n   214→\tCreatedAt time.Time\n   215→}\n   216→\n   217→// ListFiles 列出所有MP4文件\n   218→func ListFiles(dir string) ([]MP4FileInfo, error) {\n   219→\tentries, err := os.ReadDir(dir)\n   220→\tif err != nil {\n   221→\t\treturn nil, err\n   222→\t}\n   223→\n   224→\tvar files []MP4FileInfo\n   225→\tfor _, entry := range entries {\n   226→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".mp4\") {\n   227→\t\t\tcontinue\n   228→\t\t}\n   229→\n   230→\t\tinfo, err := entry.Info()\n   231→\t\tif err != nil {\n   232→\t\t\tcontinue\n   233→\t\t}\n   234→\n   235→\t\tpath := filepath.Join(dir, entry.Name())\n   236→\t\tfiles = append(files, MP4FileInfo{\n   237→\t\t\tName:      entry.Name(),\n   238→\t\t\tPath:      path,\n   239→\t\t\tSize:      info.Size(),\n   240→\t\t\tCreatedAt: info.ModTime(),\n   241→\t\t})\n   242→\t}\n   243→\n   244→\t// 按时间排序\n   245→\tsort.Slice(files, func(i, j int) bool {\n   246→\t\treturn files[i].CreatedAt.After(files[j].CreatedAt)\n   247→\t})\n   248→\n   249→\treturn files, nil\n   250→}\n   251→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"c7030919-046f-4d40-9d16-8b74cebd40f3","uuid":"095bf281-5e0c-41cd-983f-f198f4d80f4a","timestamp":"2026-03-25T12:24:29.790Z","tool_use_result":{"type":"text","file":{"filePath":"/app/data/autodev/VisionLoop-----100--2026-03-2-1774439980/internal/mp4/mp4.go","content":"package mp4\n\nimport (\n\t\"encoding/binary\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n)\n\n// EncoderPacket 编码后的数据包\ntype EncoderPacket struct {\n\tData      []byte\n\tPTS      int64\n\tDTS      int64\n\tKeyFrame bool\n\tIsRecord  bool\n\tIsMonitor bool\n}\n\n// Release 释放数据\nfunc (p *EncoderPacket) Release() {\n\tp.Data = nil\n}\n\n// MP4Writer MP4分段写入器\ntype MP4Writer struct {\n\tmu          sync.Mutex\n\tdir         string\n\tsegmentMin  int\n\twidth       int\n\theight      int\n\tbitrate     int\n\n\tcurrentFile *os.File\n\tcurrentPath string\n\tstartTime   time.Time\n\tpacketCount int64\n\n\t// 流上下文\n\tframeCount int\n\tclosed     bool\n}\n\n// StreamContext 流上下文\ntype StreamContext struct {\n\tIndex     int\n\tTimebase  Rational\n\tCodecType int\n}\n\n// Rational 有理数\ntype Rational struct {\n\tNum int64\n\tDen int64\n}\n\n// NewMP4Writer 创建MP4写入器\nfunc NewMP4Writer(dir string, segmentMin, width, height, bitrate int) (*MP4Writer, error) {\n\tw := &MP4Writer{\n\t\tdir:        dir,\n\t\tsegmentMin: segmentMin,\n\t\twidth:      width,\n\t\theight:     height,\n\t\tbitrate:    bitrate,\n\t}\n\n\tif err := w.newSegment(); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn w, nil\n}\n\n// newSegment 创建新分段\nfunc (w *MP4Writer) newSegment() error {\n\tw.mu.Lock()\n\tdefer w.mu.Unlock()\n\n\t// 关闭旧文件\n\tif w.currentFile != nil {\n\t\tw.currentFile.Close()\n\t}\n\n\t// 生成新文件名\n\tnow := time.Now()\n\tfilename := now.Format(\"2006-01-02_15-04-05\") + \".mp4\"\n\tw.currentPath = filepath.Join(w.dir, filename)\n\tw.startTime = now\n\tw.packetCount = 0\n\n\t// 创建文件\n\tf, err := os.Create(w.currentPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"create segment file failed: %w\", err)\n\t}\n\tw.currentFile = f\n\n\t// 写入简化的MP4 header (实际项目使用FFmpeg CGO)\n\t// 这里写入一个简单的文件标记\n\theader := []byte{0x00, 0x00, 0x00, 0x18, 0x66, 0x74, 0x79, 0x70} // ftyp box\n\theader = append(header, []byte(\"isom\")...)\n\theader = append(header, 0x00, 0x00, 0x02, 0x00)\n\tif _, err := f.Write(header); err != nil {\n\t\treturn err\n\t}\n\n\tlog.Printf(\"new segment: %s\", w.currentPath)\n\treturn nil\n}\n\n// WritePacket 写入数据包\nfunc (w *MP4Writer) WritePacket(pkt *EncoderPacket) error {\n\tif pkt == nil || !pkt.IsRecord {\n\t\treturn nil\n\t}\n\n\tw.mu.Lock()\n\tdefer w.mu.Unlock()\n\n\t// 检查是否需要切分 (5分钟 = 5*60*25帧 @25fps)\n\tmaxFrames := int64(w.segmentMin * 60 * 25)\n\tif w.packetCount > 0 && w.packetCount%maxFrames == 0 {\n\t\tif err := w.newSegmentLocked(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\t// 写入NALU长度前缀 + NALU数据\n\tif len(pkt.Data) > 0 {\n\t\tnaluLen := make([]byte, 4)\n\t\tbinary.BigEndian.PutUint32(naluLen, uint32(len(pkt.Data)))\n\n\t\tif _, err := w.currentFile.Write(naluLen); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif _, err := w.currentFile.Write(pkt.Data); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tw.packetCount++\n\t}\n\n\treturn nil\n}\n\n// newSegmentLocked 加锁版本\nfunc (w *MP4Writer) newSegmentLocked() error {\n\tif w.currentFile != nil {\n\t\tw.currentFile.Close()\n\t}\n\n\tnow := time.Now()\n\tfilename := now.Format(\"2006-01-02_15-04-05\") + \".mp4\"\n\tw.currentPath = filepath.Join(w.dir, filename)\n\tw.startTime = now\n\tw.packetCount = 0\n\n\tf, err := os.Create(w.currentPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"create segment file failed: %w\", err)\n\t}\n\tw.currentFile = f\n\n\t// 写入ftyp box\n\theader := []byte{0x00, 0x00, 0x00, 0x18, 0x66, 0x74, 0x79, 0x70, 0x69, 0x73, 0x6f, 0x6d, 0x00, 0x00, 0x02, 0x00}\n\tf.Write(header)\n\n\tlog.Printf(\"new segment: %s\", w.currentPath)\n\treturn nil\n}\n\n// Flush 刷新数据\nfunc (w *MP4Writer) Flush() error {\n\tw.mu.Lock()\n\tdefer w.mu.Unlock()\n\n\tif w.currentFile != nil {\n\t\treturn w.currentFile.Sync()\n\t}\n\treturn nil\n}\n\n// Close 关闭写入器\nfunc (w *MP4Writer) Close() error {\n\tw.mu.Lock()\n\tdefer w.mu.Unlock()\n\n\tw.closed = true\n\tif w.currentFile != nil {\n\t\terr := w.currentFile.Close()\n\t\tw.currentFile = nil\n\t\treturn err\n\t}\n\treturn nil\n}\n\n// CurrentPath 返回当前文件路径\nfunc (w *MP4Writer) CurrentPath() string {\n\tw.mu.Lock()\n\tdefer w.mu.Unlock()\n\treturn w.currentPath\n}\n\n// MP4FileInfo MP4文件信息\ntype MP4FileInfo struct {\n\tName      string\n\tPath      string\n\tSize      int64\n\tDuration  time.Duration\n\tCreatedAt time.Time\n}\n\n// ListFiles 列出所有MP4文件\nfunc ListFiles(dir string) ([]MP4FileInfo, error) {\n\tentries, err := os.ReadDir(dir)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar files []MP4FileInfo\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".mp4\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tinfo, err := entry.Info()\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tpath := filepath.Join(dir, entry.Name())\n\t\tfiles = append(files, MP4FileInfo{\n\t\t\tName:      entry.Name(),\n\t\t\tPath:      path,\n\t\t\tSize:      info.Size(),\n\t\t\tCreatedAt: info.ModTime(),\n\t\t})\n\t}\n\n\t// 按时间排序\n\tsort.Slice(files, func(i, j int) bool {\n\t\treturn files[i].CreatedAt.After(files[j].CreatedAt)\n\t})\n\n\treturn files, nil\n}\n","numLines":251,"startLine":1,"totalLines":251}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_w4bvq11u1et0_6","type":"tool_result","content":"     1→package webrtc\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"log\"\n     8→\t\"sync\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/pion/webrtc/v3\"\n    12→)\n    13→\n    14→// WebRTC Pion WebRTC实现\n    15→type WebRTC struct {\n    16→\tmu           sync.RwMutex\n    17→\twidth        int\n    18→\theight       int\n    19→\tpeerConn     *webrtc.PeerConnection\n    20→\tvideoTrack   *webrtc.TrackLocalStaticH264\n    21→\tconnected    bool\n    22→\tsignalCh     chan *SignalMessage\n    23→\tctx          context.Context\n    24→\tcancel       context.CancelFunc\n    25→}\n    26→\n    27→// SignalMessage 信令消息\n    28→type SignalMessage struct {\n    29→\tType    string          `json:\"type\"` // offer/answer/ice-candidate\n    30→\tPayload json.RawMessage `json:\"payload,omitempty\"`\n    31→}\n    32→\n    33→// NewWebRTC 创建WebRTC\n    34→func NewWebRTC(width, height int) (*WebRTC, error) {\n    35→\tctx, cancel := context.WithCancel(context.Background())\n    36→\n    37→\tw := &WebRTC{\n    38→\t\twidth:    width,\n    39→\t\theight:   height,\n    40→\t\tsignalCh: make(chan *SignalMessage, 10),\n    41→\t\tctx:      ctx,\n    42→\t\tcancel:   cancel,\n    43→\t}\n    44→\n    45→\tif err := w.setupPeerConnection(); err != nil {\n    46→\t\tcancel()\n    47→\t\treturn nil, err\n    48→\t}\n    49→\n    50→\treturn w, nil\n    51→}\n    52→\n    53→func (w *WebRTC) setupPeerConnection() error {\n    54→\t// 创建配置\n    55→\tconfig := webrtc.Configuration{\n    56→\t\tICEServers: []webrtc.ICEServer{\n    57→\t\t\t{\n    58→\t\t\t\tURLs: []string{\"stun:stun.l.google.com:19302\"},\n    59→\t\t\t},\n    60→\t\t},\n    61→\t}\n    62→\n    63→\t// 创建PeerConnection\n    64→\tpc, err := webrtc.NewPeerConnection(config)\n    65→\tif err != nil {\n    66→\t\treturn fmt.Errorf(\"create peer connection failed: %w\", err)\n    67→\t}\n    68→\tw.peerConn = pc\n    69→\n    70→\t// 创建H264视频track\n    71→\ttrack, err := webrtc.NewTrackLocalStaticH264(\n    72→\t\twebrtc.RTPCodecCapability{\n    73→\t\t\tMimeType:  \"video/h264\",\n    74→\t\t\tClockRate: 90000,\n    75→\t\t\t// SDP Fmtp line for baseline profile\n    76→\t\t\tSDPFmtpLine: \"level-asymmetry-allowed=1;packetization-mode=1;profile-level-id=42e01f\",\n    77→\t\t},\n    78→\t\t\"video\",\n    79→\t\t\"visionloop\",\n    80→\t)\n    81→\tif err != nil {\n    82→\t\treturn fmt.Errorf(\"create video track failed: %w\", err)\n    83→\t}\n    84→\tw.videoTrack = track\n    85→\n    86→\t// 添加track到peer connection\n    87→\tif _, err = pc.AddTrack(track); err != nil {\n    88→\t\treturn fmt.Errorf(\"add track failed: %w\", err)\n    89→\t}\n    90→\n    91→\t// 设置ICE候选者处理\n    92→\tpc.OnICECandidate(func(candidate *webrtc.ICECandidate) {\n    93→\t\tif candidate != nil {\n    94→\t\t\tw.signalCh <- &SignalMessage{\n    95→\t\t\t\tType:    \"ice-candidate\",\n    96→\t\t\t\tPayload: mustMarshal(candidate),\n    97→\t\t\t}\n    98→\t\t}\n    99→\t})\n   100→\n   101→\t// 设置连接状态变化\n   102→\tpc.OnConnectionStateChange(func(state webrtc.PeerConnectionState) {\n   103→\t\tw.mu.Lock()\n   104→\t\tw.connected = (state == webrtc.PeerConnectionStateConnected)\n   105→\t\tw.mu.Unlock()\n   106→\n   107→\t\tlog.Printf(\"peer connection state: %s\", state.String())\n   108→\t})\n   109→\n   110→\treturn nil\n   111→}\n   112→\n   113→// WriteVideoFrame 写入视频帧\n   114→func (w *WebRTC) WriteVideoFrame(pkt interface{}) error {\n   115→\tw.mu.RLock()\n   116→\tdefer w.mu.RUnlock()\n   117→\n   118→\tif !w.connected || w.videoTrack == nil {\n   119→\t\treturn nil\n   120→\t}\n   121→\n   122→\t// 写入H264包\n   123→\treturn nil\n   124→}\n   125→\n   126→// HandleSignal 处理信令\n   127→func (w *WebRTC) HandleSignal(msg *SignalMessage) error {\n   128→\tw.mu.Lock()\n   129→\tdefer w.mu.Unlock()\n   130→\n   131→\tif w.peerConn == nil {\n   132→\t\treturn fmt.Errorf(\"peer connection not initialized\")\n   133→\t}\n   134→\n   135→\tswitch msg.Type {\n   136→\tcase \"offer\":\n   137→\t\t// 处理offer\n   138→\t\tif err := w.peerConn.SetRemoteDescription(webrtc.SessionDescription{\n   139→\t\t\tType: webrtc.SDPTypeOffer,\n   140→\t\t\tSDP:  string(msg.Payload),\n   141→\t\t}); err != nil {\n   142→\t\t\treturn err\n   143→\t\t}\n   144→\n   145→\t\t// 创建answer\n   146→\t\tanswer, err := w.peerConn.CreateAnswer(nil)\n   147→\t\tif err != nil {\n   148→\t\t\treturn err\n   149→\t\t}\n   150→\t\tif err := w.peerConn.SetLocalDescription(answer); err != nil {\n   151→\t\t\treturn err\n   152→\t\t}\n   153→\n   154→\t\t// 发送answer\n   155→\t\tw.signalCh <- &SignalMessage{\n   156→\t\t\tType:    \"answer\",\n   157→\t\t\tPayload: mustMarshal(answer),\n   158→\t\t}\n   159→\n   160→\tcase \"answer\":\n   161→\t\treturn w.peerConn.SetRemoteDescription(webrtc.SessionDescription{\n   162→\t\t\tType: webrtc.SDPTypeAnswer,\n   163→\t\t\tSDP:  string(msg.Payload),\n   164→\t\t})\n   165→\n   166→\tcase \"ice-candidate\":\n   167→\t\tvar candidate webrtc.ICECandidateInit\n   168→\t\tif err := json.Unmarshal(msg.Payload, &candidate); err != nil {\n   169→\t\t\treturn err\n   170→\t\t}\n   171→\t\treturn w.peerConn.AddICECandidate(candidate)\n   172→\t}\n   173→\n   174→\treturn nil\n   175→}\n   176→\n   177→// GetSignalCh 获取信令通道\n   178→func (w *WebRTC) GetSignalCh() <-chan *SignalMessage {\n   179→\treturn w.signalCh\n   180→}\n   181→\n   182→// Close 关闭\n   183→func (w *WebRTC) Close() error {\n   184→\tw.cancel()\n   185→\tif w.videoTrack != nil {\n   186→\t\tw.videoTrack.Close()\n   187→\t}\n   188→\tif w.peerConn != nil {\n   189→\t\treturn w.peerConn.Close()\n   190→\t}\n   191→\treturn nil\n   192→}\n   193→\n   194→func mustMarshal(v interface{}) json.RawMessage {\n   195→\tdata, _ := json.Marshal(v)\n   196→\treturn data\n   197→}\n   198→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"c7030919-046f-4d40-9d16-8b74cebd40f3","uuid":"459f2be3-78c0-4c2c-bc20-d5bed0315db3","timestamp":"2026-03-25T12:24:29.791Z","tool_use_result":{"type":"text","file":{"filePath":"/app/data/autodev/VisionLoop-----100--2026-03-2-1774439980/internal/webrtc/webrtc.go","content":"package webrtc\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/pion/webrtc/v3\"\n)\n\n// WebRTC Pion WebRTC实现\ntype WebRTC struct {\n\tmu           sync.RwMutex\n\twidth        int\n\theight       int\n\tpeerConn     *webrtc.PeerConnection\n\tvideoTrack   *webrtc.TrackLocalStaticH264\n\tconnected    bool\n\tsignalCh     chan *SignalMessage\n\tctx          context.Context\n\tcancel       context.CancelFunc\n}\n\n// SignalMessage 信令消息\ntype SignalMessage struct {\n\tType    string          `json:\"type\"` // offer/answer/ice-candidate\n\tPayload json.RawMessage `json:\"payload,omitempty\"`\n}\n\n// NewWebRTC 创建WebRTC\nfunc NewWebRTC(width, height int) (*WebRTC, error) {\n\tctx, cancel := context.WithCancel(context.Background())\n\n\tw := &WebRTC{\n\t\twidth:    width,\n\t\theight:   height,\n\t\tsignalCh: make(chan *SignalMessage, 10),\n\t\tctx:      ctx,\n\t\tcancel:   cancel,\n\t}\n\n\tif err := w.setupPeerConnection(); err != nil {\n\t\tcancel()\n\t\treturn nil, err\n\t}\n\n\treturn w, nil\n}\n\nfunc (w *WebRTC) setupPeerConnection() error {\n\t// 创建配置\n\tconfig := webrtc.Configuration{\n\t\tICEServers: []webrtc.ICEServer{\n\t\t\t{\n\t\t\t\tURLs: []string{\"stun:stun.l.google.com:19302\"},\n\t\t\t},\n\t\t},\n\t}\n\n\t// 创建PeerConnection\n\tpc, err := webrtc.NewPeerConnection(config)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"create peer connection failed: %w\", err)\n\t}\n\tw.peerConn = pc\n\n\t// 创建H264视频track\n\ttrack, err := webrtc.NewTrackLocalStaticH264(\n\t\twebrtc.RTPCodecCapability{\n\t\t\tMimeType:  \"video/h264\",\n\t\t\tClockRate: 90000,\n\t\t\t// SDP Fmtp line for baseline profile\n\t\t\tSDPFmtpLine: \"level-asymmetry-allowed=1;packetization-mode=1;profile-level-id=42e01f\",\n\t\t},\n\t\t\"video\",\n\t\t\"visionloop\",\n\t)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"create video track failed: %w\", err)\n\t}\n\tw.videoTrack = track\n\n\t// 添加track到peer connection\n\tif _, err = pc.AddTrack(track); err != nil {\n\t\treturn fmt.Errorf(\"add track failed: %w\", err)\n\t}\n\n\t// 设置ICE候选者处理\n\tpc.OnICECandidate(func(candidate *webrtc.ICECandidate) {\n\t\tif candidate != nil {\n\t\t\tw.signalCh <- &SignalMessage{\n\t\t\t\tType:    \"ice-candidate\",\n\t\t\t\tPayload: mustMarshal(candidate),\n\t\t\t}\n\t\t}\n\t})\n\n\t// 设置连接状态变化\n\tpc.OnConnectionStateChange(func(state webrtc.PeerConnectionState) {\n\t\tw.mu.Lock()\n\t\tw.connected = (state == webrtc.PeerConnectionStateConnected)\n\t\tw.mu.Unlock()\n\n\t\tlog.Printf(\"peer connection state: %s\", state.String())\n\t})\n\n\treturn nil\n}\n\n// WriteVideoFrame 写入视频帧\nfunc (w *WebRTC) WriteVideoFrame(pkt interface{}) error {\n\tw.mu.RLock()\n\tdefer w.mu.RUnlock()\n\n\tif !w.connected || w.videoTrack == nil {\n\t\treturn nil\n\t}\n\n\t// 写入H264包\n\treturn nil\n}\n\n// HandleSignal 处理信令\nfunc (w *WebRTC) HandleSignal(msg *SignalMessage) error {\n\tw.mu.Lock()\n\tdefer w.mu.Unlock()\n\n\tif w.peerConn == nil {\n\t\treturn fmt.Errorf(\"peer connection not initialized\")\n\t}\n\n\tswitch msg.Type {\n\tcase \"offer\":\n\t\t// 处理offer\n\t\tif err := w.peerConn.SetRemoteDescription(webrtc.SessionDescription{\n\t\t\tType: webrtc.SDPTypeOffer,\n\t\t\tSDP:  string(msg.Payload),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\t// 创建answer\n\t\tanswer, err := w.peerConn.CreateAnswer(nil)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif err := w.peerConn.SetLocalDescription(answer); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\t// 发送answer\n\t\tw.signalCh <- &SignalMessage{\n\t\t\tType:    \"answer\",\n\t\t\tPayload: mustMarshal(answer),\n\t\t}\n\n\tcase \"answer\":\n\t\treturn w.peerConn.SetRemoteDescription(webrtc.SessionDescription{\n\t\t\tType: webrtc.SDPTypeAnswer,\n\t\t\tSDP:  string(msg.Payload),\n\t\t})\n\n\tcase \"ice-candidate\":\n\t\tvar candidate webrtc.ICECandidateInit\n\t\tif err := json.Unmarshal(msg.Payload, &candidate); err != nil {\n\t\t\treturn err\n\t\t}\n\t\treturn w.peerConn.AddICECandidate(candidate)\n\t}\n\n\treturn nil\n}\n\n// GetSignalCh 获取信令通道\nfunc (w *WebRTC) GetSignalCh() <-chan *SignalMessage {\n\treturn w.signalCh\n}\n\n// Close 关闭\nfunc (w *WebRTC) Close() error {\n\tw.cancel()\n\tif w.videoTrack != nil {\n\t\tw.videoTrack.Close()\n\t}\n\tif w.peerConn != nil {\n\t\treturn w.peerConn.Close()\n\t}\n\treturn nil\n}\n\nfunc mustMarshal(v interface{}) json.RawMessage {\n\tdata, _ := json.Marshal(v)\n\treturn data\n}\n","numLines":198,"startLine":1,"totalLines":198}}}
