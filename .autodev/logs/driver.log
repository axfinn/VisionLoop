}\n\n\treturn nil\n}\n\n// GetSignalCh 获取信令通道\nfunc (w *WebRTC) GetSignalCh() <-chan *SignalMessage {\n\treturn w.signalCh\n}\n\n// Close 关闭\nfunc (w *WebRTC) Close() error {\n\tw.cancel()\n\tif w.videoTrack != nil {\n\t\tw.videoTrack.Close()\n\t}\n\tif w.peerConn != nil {\n\t\treturn w.peerConn.Close()\n\t}\n\treturn nil\n}\n\nfunc mustMarshal(v interface{}) json.RawMessage {\n\tdata, _ := json.Marshal(v)\n\treturn data\n}\n","structuredPatch":[{"oldStart":119,"oldLines":13,"newStart":119,"newLines":17,"lines":["     return nil","   }"," ","-  // 写入H264包 (支持 encoder.EncoderPacket 或 mp4.EncoderPacket)","-  if ep, ok := pkt.(interface{ GetData() []byte }); ok {","-    data := ep.GetData()","-    if len(data) > 0 {","-      if _, err := w.videoTrack.Write(data); err != nil {","-        return fmt.Errorf(\"write video frame failed: %w\", err)","-      }","+  // 从 EncoderPacket (encoder包) 或 mp4.EncoderPacket 获取数据","+  var data []byte","+  switch ep := pkt.(type) {","+  case *encoder.EncoderPacket:","+    data = ep.Data","+  case *mp4.EncoderPacket:","+    data = ep.Data","+  }","+  if len(data) > 0 {","+    if _, err := w.videoTrack.Write(data); err != nil {","+      return fmt.Errorf(\"write video frame failed: %w\", err)","     }","   }","   return nil"]}],"userModified":false,"replaceAll":false}}
