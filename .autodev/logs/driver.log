<span>{{ settings.maxStorageGB }} GB</span>\n        </div>\n        <div class=\"storage-bar\">\n          <div class=\"storage-used\" :style=\"{ width: storageInfo.usedPercent + '%' }\"></div>\n        </div>\n        <div class=\"storage-text\">\n          已使用 {{ storageInfo.usedGB.toFixed(2) }} GB / {{ storageInfo.maxGB.toFixed(2) }} GB\n        </div>\n      </div>\n\n      <div class=\"setting-item\">\n        <label>录像分段时长</label>\n        <select v-model.number=\"settings.segmentMin\">\n          <option :value=\"1\">1 分钟</option>\n          <option :value=\"5\">5 分钟</option>\n          <option :value=\"10\">10 分钟</option>\n          <option :value=\"30\">30 分钟</option>\n        </select>\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <h2>检测设置</h2>\n      <div class=\"setting-item\">\n        <label>事件检测</label>\n        <div class=\"toggle-group\">\n          <label class=\"toggle\">\n            <input type=\"checkbox\" v-model=\"settings.detectFall\" />\n            <span>摔倒检测</span>\n          </label>\n          <label class=\"toggle\">\n            <input type=\"checkbox\" v-model=\"settings.detectCry\" />\n            <span>哭声检测</span>\n          </label>\n          <label class=\"toggle\">\n            <input type=\"checkbox\" v-model=\"settings.detectNoise\" />\n            <span>异响检测</span>\n          </label>\n          <label class=\"toggle\">\n            <input type=\"checkbox\" v-model=\"settings.detectIntruder\" />\n            <span>陌生人闯入</span>\n          </label>\n        </div>\n      </div>\n\n      <div class=\"setting-item\">\n        <label>检测灵敏度</label>\n        <div class=\"slider-group\">\n          <input type=\"range\" min=\"0.1\" max=\"1.0\" step=\"0.1\" v-model.number=\"settings.sensitivity\" />\n          <span>{{ (settings.sensitivity * 100).toFixed(0) }}%</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <h2>系统信息</h2>\n      <div class=\"info-grid\">\n        <div class=\"info-item\">\n          <span class=\"info-label\">版本</span>\n          <span class=\"info-value\">{{ systemInfo.version }}</span>\n        </div>\n        <div class=\"info-item\">\n          <span class=\"info-label\">运行时间</span>\n          <span class=\"info-value\">{{ systemInfo.uptime }}</span>\n        </div>\n        <div class=\"info-item\">\n          <span class=\"info-label\">编码帧数</span>\n          <span class=\"info-value\">{{ systemInfo.frameCount }}</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"actions\">\n      <button class=\"btn\" @click=\"saveSettings\">保存设置</button>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, computed } from 'vue'\nimport axios from 'axios'\n\nconst settings = ref({\n  maxStorageGB: 50,\n  segmentMin: 5,\n  detectFall: true,\n  detectCry: true,\n  detectNoise: true,\n  detectIntruder: true,\n  sensitivity: 0.7\n})\n\nconst storageInfo = ref({\n  used: 0,\n  max: 0,\n  usedGB: 0,\n  maxGB: 0,\n  usedPercent: 0\n})\n\nconst systemInfo = ref({\n  version: '1.0.0',\n  uptime: '0:00:00',\n  frameCount: 0\n})\n\nonMounted(async () => {\n  await loadSettings()\n  await loadStorageInfo()\n  await loadSystemInfo()\n})\n\nasync function loadSettings() {\n  try {\n    const res = await axios.get('/api/settings')\n    if (res.data) {\n      Object.assign(settings.value, res.data)\n    }\n  } catch (err) {\n    console.error('load settings error:', err)\n  }\n}\n\nasync function loadStorageInfo() {\n  try {\n    const res = await axios.get('/api/storage')\n    storageInfo.value = res.data\n  } catch (err) {\n    console.error('load storage error:', err)\n  }\n}\n\nasync function loadSystemInfo() {\n  try {\n    const res = await axios.get('/health')\n    systemInfo.value.version = res.data.version || '1.0.0'\n  } catch (err) {\n    console.error('load system info error:', err)\n  }\n}\n\nasync function saveSettings() {\n  try {\n    await axios.post('/api/settings', settings.value)\n    alert('设置已保存')\n  } catch (err) {\n    console.error('save settings error:', err)\n    alert('保存失败')\n  }\n}\n</script>\n\n<style scoped>\n.settings-view { max-width: 800px; margin: 0 auto; }\n.setting-item { margin-bottom: 1.5rem; }\n.setting-item label { display: block; font-weight: 600; margin-bottom: 0.5rem; }\n.slider-group { display: flex; align-items: center; gap: 1rem; }\n.slider-group input[type=\"range\"] { flex: 1; }\n.toggle-group { display: flex; flex-wrap: wrap; gap: 1rem; }\n.toggle { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; }\n.toggle input { width: 18px; height: 18px; }\n.storage-bar { height: 8px; background: #333; border-radius: 4px; overflow: hidden; margin-top: 0.5rem; }\n.storage-used { height: 100%; background: #00d4ff; transition: width 0.3s; }\n.storage-text { font-size: 0.85rem; color: #888; margin-top: 0.25rem; }\nselect { padding: 0.5rem 1rem; min-width: 150px; }\n.info-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }\n.info-item { background: #2a2a2a; padding: 1rem; border-radius: 4px; text-align: center; }\n.info-label { display: block; color: #888; font-size: 0.85rem; margin-bottom: 0.25rem; }\n.info-value { font-size: 1.2rem; font-weight: 600; }\n.actions { margin-top: 1.5rem; }\n.actions .btn { min-width: 120px; }\n</style>\n","numLines":181,"startLine":1,"totalLines":181}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_1x873yr7e2zf_6","type":"tool_result","content":"     1→\"\"\"\n     2→YOLOv8 检测器\n     3→支持姿态检测和人流检测\n     4→\"\"\"\n     5→\n     6→import os\n     7→import sys\n     8→import time\n     9→import numpy as np\n    10→\n    11→# 尝试导入ultralytics YOLO\n    12→try:\n    13→    from ultralytics import YOLO\n    14→    HAS_ULTRALYTICS = True\n    15→except ImportError:\n    16→    HAS_ULTRALYTICS = False\n    17→    print(\"[YOLO] Warning: ultralytics not installed, using fallback\")\n    18→\n    19→try:\n    20→    import cv2\n    21→    import torch\n    22→    HAS_TORCH = True\n    23→except ImportError:\n    24→    HAS_TORCH = False\n    25→    print(\"[YOLO] Warning: torch/cv2 not installed\")\n    26→\n    27→\n    28→class YOLODetector:\n    29→    \"\"\"YOLOv8检测器\"\"\"\n    30→\n    31→    def __init__(self, pose_model=\"yolov8n-pose.pt\", person_model=\"yolov8n.pt\"):\n    32→        self.pose_model_path = pose_model\n    33→        self.person_model_path = person_model\n    34→\n    35→        self.pose_model = None\n    36→        self.person_model = None\n    37→\n    38→        if HAS_ULTRALYTICS and HAS_TORCH:\n    39→            self._load_models()\n    40→\n    41→    def _load_models(self):\n    42→        \"\"\"加载模型\"\"\"\n    43→        try:\n    44→            if os.path.exists(self.pose_model_path):\n    45→                self.pose_model = YOLO(self.pose_model_path)\n    46→                print(f\"[YOLO] Pose model loaded: {self.pose_model_path}\")\n    47→            else:\n    48→                # 尝试从ultralytics下载\n    49→                self.pose_model = YOLO(\"yolov8n-pose.pt\")\n    50→                print(\"[YOLO] Pose model downloaded\")\n    51→        except Exception as e:\n    52→            print(f\"[YOLO] Failed to load pose model: {e}\")\n    53→\n    54→        try:\n    55→            if os.path.exists(self.person_model_path):\n    56→                self.person_model = YOLO(self.person_model_path)\n    57→                print(f\"[YOLO] Person model loaded: {self.person_model_path}\")\n    58→            else:\n    59→                self.person_model = YOLO(\"yolov8n.pt\")\n    60→                print(\"[YOLO] Person model downloaded\")\n    61→        except Exception as e:\n    62→            print(f\"[YOLO] Failed to load person model: {e}\")\n    63→\n    64→    def detect(self, data, width, height, channels=3):\n    65→        \"\"\"\n    66→        检测帧中的目标\n    67→\n    68→        Args:\n    69→            data: 原始图像数据 (RGB)\n    70→            width: 图像宽度\n    71→            height: 图像高度\n    72→            channels: 通道数\n    73→\n    74→        Returns:\n    75→            检测结果列表\n    76→        \"\"\"\n    77→        results = []\n    78→\n    79→        # 转换为numpy数组\n    80→        img = np.frombuffer(data, dtype=np.uint8)\n    81→        if channels == 3:\n    82→            img = img.reshape((height, width, 3))\n    83→            # BGR to RGB\n    84→            img = img[:, :, ::-1]\n    85→        else:\n    86→            img = img.reshape((height, width))\n    87→\n    88→        # 姿态检测 - 摔倒\n    89→        if self.pose_model is not None:\n    90→            pose_results = self._detect_pose(img)\n    91→            results.extend(pose_results)\n    92→\n    93→        # 人形检测 - 陌生人\n    94→        if self.person_model is not None:\n    95→            person_results = self._detect_person(img)\n    96→            results.extend(person_results)\n    97→\n    98→        return results\n    99→\n   100→    def _detect_pose(self, img):\n   101→        \"\"\"姿态检测\"\"\"\n   102→        results = []\n   103→\n   104→        if self.pose_model is None:\n   105→            return results\n   106→\n   107→        try:\n   108→            # 推理\n   109→            preds = self.pose_model(img, verbose=False)\n   110→\n   111→            for pred in preds:\n   112→                if pred.keypoints is None:\n   113→                    continue\n   114→\n   115→                keypoints = pred.keypoints.xy.cpu().numpy()\n   116→                if len(keypoints) == 0:\n   117→                    continue\n   118→\n   119→                # 获取关键点\n   120→                kp = keypoints[0]  # 第一个人的关键点\n   121→\n   122→                # 检查摔倒 (简单算法: 头和脚的高度差小)\n   123→                if len(kp) >= 17:\n   124→                    # 肩膀中点\n   125→                    left_shoulder = kp[5]\n   126→                    right_shoulder = kp[6]\n   127→                    shoulder_mid = (left_shoulder + right_shoulder) / 2\n   128→\n   129→                    # 髋部中点\n   130→                    left_hip = kp[11]\n   131→                    right_hip = kp[12]\n   132→                    hip_mid = (left_hip + right_hip) / 2\n   133→\n   134→                    # 脚\n   135→                    left_foot = kp[17] if len(kp) > 17 else kp[15]\n   136→                    right_foot = kp[18] if len(kp) > 18 else kp[16]\n   137→\n   138→                    # 头部 (鼻子)\n   139→                    head = kp[0]\n   140→\n   141→                    # 躯干角度\n   142→                    dx = shoulder_mid[0] - hip_mid[0]\n   143→                    dy = shoulder_mid[1] - hip_mid[1]\n   144→                    angle = abs(np.arctan2(dy, dx) * 180 / np.pi)\n   145→\n   146→                    # 高度比\n   147→                    body_height = np.linalg.norm(shoulder_mid - hip_mid)\n   148→                    width = abs(left_shoulder[0] - right_shoulder[0])\n   149→                    height_ratio = body_height / (width + 1e-6)\n   150→\n   151→                    # 摔倒判定\n   152→                    # 1. 躯干接近水平 (angle > 60 或 angle < 30)\n   153→                    # 2. 身体变矮\n   154→                    if (angle < 30 or angle > 60) and height_ratio < 1.5:\n   155→                        conf = float(pred.probs[0].cpu().numpy()) if hasattr(pred, 'probs') else 0.7\n   156→                        results.append({\n   157→                            \"type\": \"fall\",\n   158→                            \"confidence\": conf,\n   159→                            \"bbox\": pred.boxes.xyxy[0].cpu().numpy().tolist() if pred.boxes is not None else [],\n   160→                            \"keypoints\": kp.tolist(),\n   161→                        })\n   162→\n   163→        except Exception as e:\n   164→            print(f\"[YOLO] Pose detection error: {e}\")\n   165→\n   166→        return results\n   167→\n   168→    def _detect_person(self, img):\n   169→        \"\"\"人形检测\"\"\"\n   170→        results = []\n   171→\n   172→        if self.person_model is None:\n   173→            return results\n   174→\n   175→        try:\n   176→            preds = self.person_model(img, verbose=False, classes=[0])  # class 0 = person\n   177→\n   178→            for pred in preds:\n   179→                if pred.boxes is None or len(pred.boxes) == 0:\n   180→                    continue\n   181→\n   182→                boxes = pred.boxes.xyxy.cpu().numpy()\n   183→                confs = pred.boxes.conf.cpu().numpy()\n   184→\n   185→                for box, conf in zip(boxes, confs):\n   186→                    if conf > 0.5:\n   187→                        results.append({\n   188→                            \"type\": \"person\",\n   189→                            \"confidence\": float(conf),\n   190→                            \"bbox\": box.tolist(),\n   191→                        })\n   192→\n   193→        except Exception as e:\n   194→            print(f\"[YOLO] Person detection error: {e}\")\n   195→\n   196→        return results\n   197→\n   198→\n   199→def simple_fall_detection(kp):\n   200→    \"\"\"\n   201→    简单的摔倒检测算法 (无需模型)\n   202→\n   203→    基于关键点高度变化和人体角度判断\n   204→    \"\"\"\n   205→    if len(kp) < 17:\n   206→        return False, 0.0\n   207→\n   208→    # 简化: 检查肩膀和髋部的相对位置\n   209→    # 正常站立时肩膀高于髋部，摔倒时接近\n   210→    left_shoulder = kp[5]\n   211→    right_shoulder = kp[6]\n   212→    shoulder_mid_y = (left_shoulder[1] + right_shoulder[1]) / 2\n   213→\n   214→    left_hip = kp[11]\n   215→    right_hip = kp[12]\n   216→    hip_mid_y = (left_hip[1] + right_hip[1]) / 2\n   217→\n   218→    # 高度差小于阈值说明可能摔倒\n   219→    height_diff = abs(shoulder_mid_y - hip_mid_y)\n   220→    img_height = 480  # 假设\n   221→\n   222→    if height_diff < img_height * 0.1:  # 10%高度\n   223→        return True, 0.8\n   224→\n   225→    return False, 0.0\n   226→\n   227→\n   228→if __name__ == \"__main__\":\n   229→    # 测试\n   230→    import numpy as np\n   231→\n   232→    detector = YOLODetector()\n   233→\n   234→    # 生成测试图像\n   235→    test_img = np.random.randint(0, 255, (480, 640, 3), dtype=np.uint8)\n   236→\n   237→    results = detector.detect(test_img.tobytes(), 640, 480, 3)\n   238→    print(f\"Detection results: {results}\")\n   239→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"c7030919-046f-4d40-9d16-8b74cebd40f3","uuid":"d0361f90-44bf-45a5-8570-4db79605c195","timestamp":"2026-03-25T12:24:38.294Z","tool_use_result":{"type":"text","file":{"filePath":"/app/data/autodev/VisionLoop-----100--2026-03-2-1774439980/detection/yolo.py","content":"\"\"\"\nYOLOv8 检测器\n支持姿态检测和人流检测\n\"\"\"\n\nimport os\nimport sys\nimport time\nimport numpy as np\n\n# 尝试导入ultralytics YOLO\ntry:\n    from ultralytics import YOLO\n    HAS_ULTRALYTICS = True\nexcept ImportError:\n    HAS_ULTRALYTICS = False\n    print(\"[YOLO] Warning: ultralytics not installed, using fallback\")\n\ntry:\n    import cv2\n    import torch\n    HAS_TORCH = True\nexcept ImportError:\n    HAS_TORCH = False\n    print(\"[YOLO] Warning: torch/cv2 not installed\")\n\n\nclass YOLODetector:\n    \"\"\"YOLOv8检测器\"\"\"\n\n    def __init__(self, pose_model=\"yolov8n-pose.pt\", person_model=\"yolov8n.pt\"):\n        self.pose_model_path = pose_model\n        self.person_model_path = person_model\n\n        self.pose_model = None\n        self.person_model = None\n\n        if HAS_ULTRALYTICS and HAS_TORCH:\n            self._load_models()\n\n    def _load_models(self):\n        \"\"\"加载模型\"\"\"\n        try:\n            if os.path.exists(self.pose_model_path):\n                self.pose_model = YOLO(self.pose_model_path)\n                print(f\"[YOLO] Pose model loaded: {self.pose_model_path}\")\n            else:\n                # 尝试从ultralytics下载\n                self.pose_model = YOLO(\"yolov8n-pose.pt\")\n                print(\"[YOLO] Pose model downloaded\")\n        except Exception as e:\n            print(f\"[YOLO] Failed to load pose model: {e}\")\n\n        try:\n            if os.path.exists(self.person_model_path):\n                self.person_model = YOLO(self.person_model_path)\n                print(f\"[YOLO] Person model loaded: {self.person_model_path}\")\n            else:\n                self.person_model = YOLO(\"yolov8n.pt\")\n                print(\"[YOLO] Person model downloaded\")\n        except Exception as e:\n            print(f\"[YOLO] Failed to load person model: {e}\")\n\n    def detect(self, data, width, height, channels=3):\n        \"\"\"\n        检测帧中的目标\n\n        Args:\n            data: 原始图像数据 (RGB)\n            width: 图像宽度\n            height: 图像高度\n            channels: 通道数\n\n        Returns:\n            检测结果列表\n        \"\"\"\n        results = []\n\n        # 转换为numpy数组\n        img = np.frombuffer(data, dtype=np.uint8)\n        if channels == 3:\n            img = img.reshape((height, width, 3))\n            # BGR to RGB\n            img = img[:, :, ::-1]\n        else:\n            img = img.reshape((height, width))\n\n        # 姿态检测 - 摔倒\n        if self.pose_model is not None:\n            pose_results = self._detect_pose(img)\n            results.extend(pose_results)\n\n        # 人形检测 - 陌生人\n        if self.person_model is not None:\n            person_results = self._detect_person(img)\n            results.extend(person_results)\n\n        return results\n\n    def _detect_pose(self, img):\n        \"\"\"姿态检测\"\"\"\n        results = []\n\n        if self.pose_model is None:\n            return results\n\n        try:\n            # 推理\n            preds = self.pose_model(img, verbose=False)\n\n            for pred in preds:\n                if pred.keypoints is None:\n                    continue\n\n                keypoints = pred.keypoints.xy.cpu().numpy()\n                if len(keypoints) == 0:\n                    continue\n\n                # 获取关键点\n                kp = keypoints[0]  # 第一个人的关键点\n\n                # 检查摔倒 (简单算法: 头和脚的高度差小)\n                if len(kp) >= 17:\n                    # 肩膀中点\n                    left_shoulder = kp[5]\n                    right_shoulder = kp[6]\n                    shoulder_mid = (left_shoulder + right_shoulder) / 2\n\n                    # 髋部中点\n                    left_hip = kp[11]\n                    right_hip = kp[12]\n                    hip_mid = (left_hip + right_hip) / 2\n\n                    # 脚\n                    left_foot = kp[17] if len(kp) > 17 else kp[15]\n                    right_foot = kp[18] if len(kp) > 18 else kp[16]\n\n                    # 头部 (鼻子)\n                    head = kp[0]\n\n                    # 躯干角度\n                    dx = shoulder_mid[0] - hip_mid[0]\n                    dy = shoulder_mid[1] - hip_mid[1]\n                    angle = abs(np.arctan2(dy, dx) * 180 / np.pi)\n\n                    # 高度比\n                    body_height = np.linalg.norm(shoulder_mid - hip_mid)\n                    width = abs(left_shoulder[0] - right_shoulder[0])\n                    height_ratio = body_height / (width + 1e-6)\n\n                    # 摔倒判定\n                    # 1. 躯干接近水平 (angle > 60 或 angle < 30)\n                    # 2. 身体变矮\n                    if (angle < 30 or angle > 60) and height_ratio < 1.5:\n                        conf = float(pred.probs[0].cpu().numpy()) if hasattr(pred, 'probs') else 0.7\n                        results.append({\n                            \"type\": \"fall\",\n                            \"confidence\": conf,\n                            \"bbox\": pred.boxes.xyxy[0].cpu().numpy().tolist() if pred.boxes is not None else [],\n                            \"keypoints\": kp.tolist(),\n                        })\n\n        except Exception as e:\n            print(f\"[YOLO] Pose detection error: {e}\")\n\n        return results\n\n    def _detect_person(self, img):\n        \"\"\"人形检测\"\"\"\n        results = []\n\n        if self.person_model is None:\n            return results\n\n        try:\n            preds = self.person_model(img, verbose=False, classes=[0])  # class 0 = person\n\n            for pred in preds:\n                if pred.boxes is None or len(pred.boxes) == 0:\n                    continue\n\n                boxes = pred.boxes.xyxy.cpu().numpy()\n                confs = pred.boxes.conf.cpu().numpy()\n\n                for box, conf in zip(boxes, confs):\n                    if conf > 0.5:\n                        results.append({\n                            \"type\": \"person\",\n                            \"confidence\": float(conf),\n                            \"bbox\": box.tolist(),\n                        })\n\n        except Exception as e:\n            print(f\"[YOLO] Person detection error: {e}\")\n\n        return results\n\n\ndef simple_fall_detection(kp):\n    \"\"\"\n    简单的摔倒检测算法 (无需模型)\n\n    基于关键点高度变化和人体角度判断\n    \"\"\"\n    if len(kp) < 17:\n        return False, 0.0\n\n    # 简化: 检查肩膀和髋部的相对位置\n    # 正常站立时肩膀高于髋部，摔倒时接近\n    left_shoulder = kp[5]\n    right_shoulder = kp[6]\n    shoulder_mid_y = (left_shoulder[1] + right_shoulder[1]) / 2\n\n    left_hip = kp[11]\n    right_hip = kp[12]\n    hip_mid_y = (left_hip[1] + right_hip[1]) / 2\n\n    # 高度差小于阈值说明可能摔倒\n    height_diff = abs(shoulder_mid_y - hip_mid_y)\n    img_height = 480  # 假设\n\n    if height_diff < img_height * 0.1:  # 10%高度\n        return True, 0.8\n\n    return False, 0.0\n\n\nif __name__ == \"__main__\":\n    # 测试\n    import numpy as np\n\n    detector = YOLODetector()\n\n    # 生成测试图像\n    test_img = np.random.randint(0, 255, (480, 640, 3), dtype=np.uint8)\n\n    results = detector.detect(test_img.tobytes(), 640, 480, 3)\n    print(f\"Detection results: {results}\")\n","numLines":239,"startLine":1,"totalLines":239}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_1x873yr7e2zf_7","type":"tool_result","content":"     1→\"\"\"\n     2→音频检测器\n     3→基于频谱分析检测哭声和异响\n     4→\n     5→注意: 当前版本从视频帧中提取音频信息\n     6→实际项目中音频应从独立音频流获取\n     7→\"\"\"\n     8→\n     9→import os\n    10→import sys\n    11→import numpy as np\n    12→\n    13→try:\n    14→    import scipy.signal as signal\n    15→    HAS_SCIPY = True\n    16→except ImportError:\n    17→    HAS_SCIPY = False\n    18→    print(\"[Audio] Warning: scipy not installed\")\n    19→\n    20→\n    21→class AudioDetector:\n    22→    \"\"\"音频检测器\"\"\"\n    23→\n    24→    def __init__(self, sample_rate=16000):\n    25→        self.sample_rate = sample_rate\n    26→\n    27→        # 哭声特征频率范围 (1-4 kHz)\n    28→        self.cry_freq_low = 1000\n    29→        self.cry_freq_high = 4000\n    30→\n    31→        # 异响检测阈值\n    32→        self.noise_threshold = 0.3\n    33→\n    34→        # 历史帧缓存\n    35→        self.history = []\n    36→        self.history_size = 10\n    37→\n    38→    def detect(self, data, width, height, channels=3):\n    39→        \"\"\"\n    40→        从帧数据中检测音频异常\n    41→\n    42→        Args:\n    43→            data: 原始图像数据\n    44→            width: 图像宽度\n    45→            height: 图像高度\n    46→            channels: 通道数\n    47→\n    48→        Returns:\n    49→            检测结果列表\n    50→        \"\"\"\n    51→        results = []\n    52→\n    53→        # 当前实现从图像数据中模拟音频分析\n    54→        # 实际项目中需要从音频流获取PCM数据\n    55→        img = np.frombuffer(data, dtype=np.uint8).reshape((height, width, channels))\n    56→\n    57→        # 计算图像统计特征作为伪音频特征\n    58→        # 这是一个非常简化的实现\n    59→        features = self._extract_features(img)\n    60→\n    61→        # 检测哭声\n    62→        cry_result = self._detect_cry(features)\n    63→        if cry_result:\n    64→            results.append(cry_result)\n    65→\n    66→        # 检测异响\n    67→        noise_result = self._detect_noise(features)\n    68→        if noise_result:\n    69→            results.append(noise_result)\n    70→\n    71→        # 更新历史\n    72→        self.history.append(features)\n    73→        if len(self.history) > self.history_size:\n    74→            self.history.pop(0)\n    75→\n    76→        return results\n    77→\n    78→    def _extract_features(self, img):\n    79→        \"\"\"提取特征\"\"\"\n    80→        # 简化的频谱特征\n    81→        # 实际应该使用STFT\n    82→        gray = np.mean(img, axis=2)\n    83→\n    84→        # 计算水平方向的能量\n    85→        energy = np.sum(gray ** 2, axis=1)\n    86→\n    87→        # 简化的频率分析 (实际上是空间频率)\n    88→        if HAS_SCIPY:\n    89→            # 使用差分近似导数\n    90→            diff = np.diff(gray, axis=0)\n    91→            diff_energy = np.sum(diff ** 2, axis=(0, 1))\n    92→        else:\n    93→            diff_energy = float(np.var(gray))\n    94→\n    95→        return {\n    96→            \"energy\": float(np.mean(energy)),\n    97→            \"variance\": float(np.var(energy)),\n    98→            \"diff_energy\": diff_energy,\n    99→            \"max_energy\": float(np.max(energy)),\n   100→            \"min_energy\": float(np.min(energy)),\n   101→        }\n   102→\n   103→    def _detect_cry(self, features):\n   104→        \"\"\"\n   105→        检测哭声\n   106→\n   107→        哭声特征:\n   108→        - 频率集中在1-4kHz\n   109→        - 能量波动大\n   110→        - 有规律性\n   111→        \"\"\"\n   112→        if not HAS_SCIPY:\n   113→            return None\n   114→\n   115→        # 简化的哭声检测\n   116→        # 实际需要分析频谱\n   117→        energy = features[\"energy\"]\n   118→        variance = features[\"variance\"]\n   119→\n   120→        # 高能量 + 高方差 = 可能的哭声\n   121→        cry_score = (energy / 255.0) * (variance / (energy + 1e-6))\n   122→\n   123→        if cry_score > 0.5:\n   124→            return {\n   125→                \"type\": \"cry\",\n   126→                \"confidence\": min(cry_score, 1.0),\n   127→                \"frequency_range\": [self.cry_freq_low, self.cry_freq_high],\n   128→            }\n   129→\n   130→        return None\n   131→\n   132→    def _detect_noise(self, features):\n   133→        \"\"\"\n   134→        检测异响\n   135→\n   136→        异响特征:\n   137→        - 突然的能量变化\n   138→        - 频谱突然变化\n   139→        \"\"\"\n   140→        if len(self.history) < 2:\n   141→            return None\n   142→\n   143→        # 计算与历史帧的差异\n   144→        prev_features = self.history[-2]\n   145→        current_features = features\n   146→\n   147→        energy_change = abs(\n   148→            current_features[\"energy\"] - prev_features[\"energy\"]\n   149→        ) / (prev_features[\"energy\"] + 1e-6)\n   150→\n   151→        diff_change = abs(\n   152→            current_features[\"diff_energy\"] - prev_features[\"diff_energy\"]\n   153→        ) / (prev_features[\"diff_energy\"] + 1e-6)\n   154→\n   155→        # 突然变化检测\n   156→        if energy_change > self.noise_threshold or diff_change > self.noise_threshold:\n   157→            confidence = min((energy_change + diff_change) / 2, 1.0)\n   158→            if confidence > 0.3:\n   159→                return {\n   160→                    \"type\": \"noise\",\n   161→                    \"confidence\": confidence,\n   162→                    \"energy_change\": energy_change,\n   163→                    \"diff_change\": diff_change,\n   164→                }\n   165→\n   166→        return None\n   167→\n   168→    def _compute_spectrum(self, signal_data):\n   169→        \"\"\"计算频谱\"\"\"\n   170→        if not HAS_SCIPY or len(signal_data) < 2:\n   171→            return np.zeros(128)\n   172→\n   173→        # 短时傅里叶变换\n   174→        f, t, Zxx = signal.stft(\n   175→            signal_data,\n   176→            fs=self.sample_rate,\n   177→            nperseg=min(256, len(signal_data)),\n   178→        )\n   179→\n   180→        # 计算幅度谱\n   181→        magnitude = np.abs(Zxx)\n   182→        mean_spectrum = np.mean(magnitude, axis=1)\n   183→\n   184→        return mean_spectrum\n   185→\n   186→    def _band_energy(self, spectrum, freq_bins, low_freq, high_freq):\n   187→        \"\"\"计算频段能量\"\"\"\n   188→        if len(spectrum) == 0:\n   189→            return 0.0\n   190→\n   191→        # 找到对应频率的bin\n   192→        bin_low = int(low_freq * len(spectrum) / (self.sample_rate / 2))\n   193→        bin_high = int(high_freq * len(spectrum) / (self.sample_rate / 2))\n   194→\n   195→        bin_low = max(0, min(bin_low, len(spectrum) - 1))\n   196→        bin_high = max(0, min(bin_high, len(spectrum) - 1))\n   197→\n   198→        return float(np.mean(spectrum[bin_low:bin_high]))\n   199→\n   200→\n   201→def main():\n   202→    \"\"\"测试\"\"\"\n   203→    detector = AudioDetector()\n   204→\n   205→    # 生成测试数据\n   206→    test_data = np.random.randint(0, 255, (480, 640, 3), dtype=np.uint8)\n   207→\n   208→    results = detector.detect(test_data.tobytes(), 640, 480, 3)\n   209→    print(f\"Audio detection results: {results}\")\n   210→\n   211→\n   212→if __name__ == \"__main__\":\n   213→    main()\n   214→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"c7030919-046f-4d40-9d16-8b74cebd40f3","uuid":"01b5d962-5d47-49f9-ada1-7933565219f2","timestamp":"2026-03-25T12:24:38.295Z","tool_use_result":{"type":"text","file":{"filePath":"/app/data/autodev/VisionLoop-----100--2026-03-2-1774439980/detection/audio.py","content":"\"\"\"\n音频检测器\n基于频谱分析检测哭声和异响\n\n注意: 当前版本从视频帧中提取音频信息\n实际项目中音频应从独立音频流获取\n\"\"\"\n\nimport os\nimport sys\nimport numpy as np\n\ntry:\n    import scipy.signal as signal\n    HAS_SCIPY = True\nexcept ImportError:\n    HAS_SCIPY = False\n    print(\"[Audio] Warning: scipy not installed\")\n\n\nclass AudioDetector:\n    \"\"\"音频检测器\"\"\"\n\n    def __init__(self, sample_rate=16000):\n        self.sample_rate = sample_rate\n\n        # 哭声特征频率范围 (1-4 kHz)\n        self.cry_freq_low = 1000\n        self.cry_freq_high = 4000\n\n        # 异响检测阈值\n        self.noise_threshold = 0.3\n\n        # 历史帧缓存\n        self.history = []\n        self.history_size = 10\n\n    def detect(self, data, width, height, channels=3):\n        \"\"\"\n        从帧数据中检测音频异常\n\n        Args:\n            data: 原始图像数据\n            width: 图像宽度\n            height: 图像高度\n            channels: 通道数\n\n        Returns:\n            检测结果列表\n        \"\"\"\n        results = []\n\n        # 当前实现从图像数据中模拟音频分析\n        # 实际项目中需要从音频流获取PCM数据\n        img = np.frombuffer(data, dtype=np.uint8).reshape((height, width, channels))\n\n        # 计算图像统计特征作为伪音频特征\n        # 这是一个非常简化的实现\n        features = self._extract_features(img)\n\n        # 检测哭声\n        cry_result = self._detect_cry(features)\n        if cry_result:\n            results.append(cry_result)\n\n        # 检测异响\n        noise_result = self._detect_noise(features)\n        if noise_result:\n            results.append(noise_result)\n\n        # 更新历史\n        self.history.append(features)\n        if len(self.history) > self.history_size:\n            self.history.pop(0)\n\n        return results\n\n    def _extract_features(self, img):\n        \"\"\"提取特征\"\"\"\n        # 简化的频谱特征\n        # 实际应该使用STFT\n        gray = np.mean(img, axis=2)\n\n        # 计算水平方向的能量\n        energy = np.sum(gray ** 2, axis=1)\n\n        # 简化的频率分析 (实际上是空间频率)\n        if HAS_SCIPY:\n            # 使用差分近似导数\n            diff = np.diff(gray, axis=0)\n            diff_energy = np.sum(diff ** 2, axis=(0, 1))\n        else:\n            diff_energy = float(np.var(gray))\n\n        return {\n            \"energy\": float(np.mean(energy)),\n            \"variance\": float(np.var(energy)),\n            \"diff_energy\": diff_energy,\n            \"max_energy\": float(np.max(energy)),\n            \"min_energy\": float(np.min(energy)),\n        }\n\n    def _detect_cry(self, features):\n        \"\"\"\n        检测哭声\n\n        哭声特征:\n        - 频率集中在1-4kHz\n        - 能量波动大\n        - 有规律性\n        \"\"\"\n        if not HAS_SCIPY:\n            return None\n\n        # 简化的哭声检测\n        # 实际需要分析频谱\n        energy = features[\"energy\"]\n        variance = features[\"variance\"]\n\n        # 高能量 + 高方差 = 可能的哭声\n        cry_score = (energy / 255.0) * (variance / (energy + 1e-6))\n\n        if cry_score > 0.5:\n            return {\n                \"type\": \"cry\",\n                \"confidence\": min(cry_score, 1.0),\n                \"frequency_range\": [self.cry_freq_low, self.cry_freq_high],\n            }\n\n        return None\n\n    def _detect_noise(self, features):\n        \"\"\"\n        检测异响\n\n        异响特征:\n        - 突然的能量变化\n        - 频谱突然变化\n        \"\"\"\n        if len(self.history) < 2:\n            return None\n\n        # 计算与历史帧的差异\n        prev_features = self.history[-2]\n        current_features = features\n\n        energy_change = abs(\n            current_features[\"energy\"] - prev_features[\"energy\"]\n        ) / (prev_features[\"energy\"] + 1e-6)\n\n        diff_change = abs(\n            current_features[\"diff_energy\"] - prev_features[\"diff_energy\"]\n        ) / (prev_features[\"diff_energy\"] + 1e-6)\n\n        # 突然变化检测\n        if energy_change > self.noise_threshold or diff_change > self.noise_threshold:\n            confidence = min((energy_change + diff_change) / 2, 1.0)\n            if confidence > 0.3:\n                return {\n                    \"type\": \"noise\",\n                    \"confidence\": confidence,\n                    \"energy_change\": energy_change,\n                    \"diff_change\": diff_change,\n                }\n\n        return None\n\n    def _compute_spectrum(self, signal_data):\n        \"\"\"计算频谱\"\"\"\n        if not HAS_SCIPY or len(signal_data) < 2:\n            return np.zeros(128)\n\n        # 短时傅里叶变换\n        f, t, Zxx = signal.stft(\n            signal_data,\n            fs=self.sample_rate,\n            nperseg=min(256, len(signal_data)),\n        )\n\n        # 计算幅度谱\n        magnitude = np.abs(Zxx)\n        mean_spectrum = np.mean(magnitude, axis=1)\n\n        return mean_spectrum\n\n    def _band_energy(self, spectrum, freq_bins, low_freq, high_freq):\n        \"\"\"计算频段能量\"\"\"\n        if len(spectrum) == 0:\n            return 0.0\n\n        # 找到对应频率的bin\n        bin_low = int(low_freq * len(spectrum) / (self.sample_rate / 2))\n        bin_high = int(high_freq * len(spectrum) / (self.sample_rate / 2))\n\n        bin_low = max(0, min(bin_low, len(spectrum) - 1))\n        bin_high = max(0, min(bin_high, len(spectrum) - 1))\n\n        return float(np.mean(spectrum[bin_low:bin_high]))\n\n\ndef main():\n    \"\"\"测试\"\"\"\n    detector = AudioDetector()\n\n    # 生成测试数据\n    test_data = np.random.randint(0, 255, (480, 640, 3), dtype=np.uint8)\n\n    results = detector.detect(test_data.tobytes(), 640, 480, 3)\n    print(f\"Audio detection results: {results}\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":214,"startLine":1,"totalLines":214}}}
