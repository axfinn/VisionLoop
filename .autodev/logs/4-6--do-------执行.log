: inline-block; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }\n    .event-fall { background: #ff6b6b; }\n    .event-cry { background: #ffd93d; color: #000; }\n    .event-noise { background: #6bcb77; }\n    .event-intruder { background: #9b59b6; }\n    .loading { display: flex; justify-content: center; align-items: center; min-height: 200px; color: #666; }\n    .empty { text-align: center; padding: 3rem; color: #666; }\n  </style>\n</head>\n<body>\n  <div id=\"app\">\n    <header class=\"navbar\">\n      <h1>VisionLoop</h1>\n      <nav>\n        <router-link to=\"/\">实时监看</router-link>\n        <router-link to=\"/playback\">历史回放</router-link>\n        <router-link to=\"/events\">事件中心</router-link>\n        <router-link to=\"/settings\">设置</router-link>\n      </nav>\n    </header>\n    <main class=\"container\">\n      <router-view></router-view>\n    </main>\n  </div>\n  <script type=\"module\" src=\"/src/main.js\"></script>\n</body>\n</html>\n"}}],"model":"MiniMax-M2.7","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":25948,"output_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":19028},"service_tier":"standard","context_management":null},"parent_tool_use_id":null,"session_id":"8c6c89c7-3163-465f-b017-a4031aaabdb4","uuid":"e0c8d102-28d4-4643-b5e9-6db425a06e7f"}
