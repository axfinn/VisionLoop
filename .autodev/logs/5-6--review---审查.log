= 640, 480\n    76→\t\tcap.Set(gocv.VideoCaptureProperties.FrameWidth, float64(width))\n    77→\t\tcap.Set(gocv.VideoCaptureProperties.FrameHeight, float64(height))\n    78→\t}\n    79→\tif fps == 0 {\n    80→\t\tfps = 25\n    81→\t}\n    82→\n    83→\tlog.Printf(\"camera opened: %dx%d @ %.2f fps\", width, height, fps)\n    84→\n    85→\treturn &VideoCapture{\n    86→\t\tcap:    cap,\n    87→\t\twidth:  width,\n    88→\t\theight: height,\n    89→\t\tfps:    fps,\n    90→\t\tdevice: device,\n    91→\t}, nil\n    92→}\n    93→\n    94→func (c *VideoCapture) Width() int  { return c.width }\n    95→func (c *VideoCapture) Height() int { return c.height }\n    96→\n    97→func (c *VideoCapture) Close() {\n    98→\tif c.cap != nil {\n    99→\t\tc.cap.Close()\n   100→\t\tc.cap = nil\n   101→\t}\n   102→}\n   103→\n   104→// CaptureLoop 采集循环，无缓冲channel，下游满则丢帧\n   105→func (c *VideoCapture) CaptureLoop(ctx context.Context, frameCh chan<- *Frame) {\n   106→\tdefer close(frameCh)\n   107→\n   108→\t// 目标帧率\n   109→\tframeDuration := time.Duration(1e9 / int(c.fps))\n   110→\tticker := time.NewTicker(frameDuration)\n   111→\tdefer ticker.Stop()\n   112→\n   113→\tfor {\n   114→\t\tselect {\n   115→\t\tcase <-ctx.Done():\n   116→\t\t\treturn\n   117→\t\tcase <-ticker.C:\n   118→\t\t\timg := gocv.NewMat()\n   119→\t\t\tif ok := c.cap.Read(&img); !ok {\n   120→\t\t\t\timg.Close()\n   121→\t\t\t\tlog.Printf(\"camera read failed, retrying...\")\n   122→\t\t\t\ttime.Sleep(100 * time.Millisecond)\n   123→\t\t\t\tcontinue\n   124→\t\t\t}\n   125→\t\t\tif img.Empty() {\n   126→\t\t\t\timg.Close()\n   127→\t\t\t\tcontinue\n   128→\t\t\t}\n   129→\n   130→\t\t\tselect {\n   131→\t\t\tcase frameCh <- NewFrame(&img):\n   132→\t\t\t\t// 成功写入，不阻塞\n   133→\t\t\tdefault:\n   134→\t\t\t\t// channel满，丢帧\n   135→\t\t\t\timg.Close()\n   136→\t\t\t}\n   137→\t\t}\n   138→\t}\n   139→}\n   140→\n   141→// TestPattern 测试图案生成器\n   142→type TestPattern struct {\n   143→\twidth  int\n   144→\theight int\n 