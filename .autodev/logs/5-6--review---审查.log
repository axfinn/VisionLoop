title>VisionLoop - 智能监控</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0f0f0f; color: #fff; }\n    #app { min-height: 100vh; }\n    .navbar { background: #1a1a1a; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #333; }\n    .navbar h1 { font-size: 1.5rem; color: #00d4ff; }\n    .navbar nav { display: flex; gap: 1.5rem; }\n    .navbar nav a { color: #aaa; text-decoration: none; padding: 0.5rem 1rem; border-radius: 4px; transition: all 0.2s; }\n    .navbar nav a:hover, .navbar nav a.active { color: #fff; background: #00d4ff22; }\n    .container { max-width: 1400px; margin: 0 auto; padding: 2rem; }\n    .card { background: #1a1a1a; border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem; border: 1px solid #333; }\n    .card h2 { font-size: 1.2rem; margin-bottom: 1rem; color: #00d4ff; }\n    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }\n    .btn { background: #00d4ff; color: #000; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer; font-weight: 600; transition: all 0.2s; }\n    .btn:hover { background: #00b8e6; }\n    .btn-danger { background: #ff4444; color: #fff; }\n    .btn-danger:hover { background: #cc0000; }\n    input, select { background: #2a2a2a; border: 1px solid #444; color: #fff; padding: 0.5rem; border-radius: 4px; }\n    .event-badge { display: inline-block; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }\n    .event-fall { background: #ff6b6b; }\n    .event-cry { background: #ffd93d; color: #000; }\n    .event-noise { background: #6bcb77; }\n    .event-intruder { background: #9b59b6; }\n    .loading { display: flex; justify-content: center; align-items: center; min-height: 200px; color: #666; }\n    .empty { text-align: center; padding: 3rem; colo